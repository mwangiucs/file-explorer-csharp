<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Color Palette (Dark Mode) ─────────────────────────────────── -->
    <Color x:Key="Blue900">#07111E</Color>
    <Color x:Key="Blue800">#0C1E36</Color>
    <Color x:Key="Blue700">#122A4A</Color>
    <Color x:Key="Blue600">#183C66</Color>
    <Color x:Key="Blue500">#235085</Color>
    <Color x:Key="Blue400">#60A5FA</Color>
    <Color x:Key="Blue200">#3B82F6</Color>
    <Color x:Key="Blue100">#1D4ED8</Color>
    <Color x:Key="Blue050">#1A2536</Color>
    <Color x:Key="Gray800">#F3F4F6</Color>
    <Color x:Key="Gray700">#E5E7EB</Color>
    <Color x:Key="Gray600">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray400">#4B5563</Color>
    <Color x:Key="Gray300">#374151</Color>
    <Color x:Key="Gray200">#1F2937</Color>
    <Color x:Key="Gray100">#252E3C</Color>
    <Color x:Key="Gray050">#111827</Color>
    <Color x:Key="RedAccent">#EF4444</Color>
    <Color x:Key="GreenAccent">#10B981</Color>
    <Color x:Key="GreenLight">#064E3B</Color>
    <Color x:Key="AmberAccent">#F59E0B</Color>

    <SolidColorBrush x:Key="Blue900Brush" Color="{StaticResource Blue900}"/>
    <SolidColorBrush x:Key="Blue800Brush" Color="{StaticResource Blue800}"/>
    <SolidColorBrush x:Key="Blue700Brush" Color="{StaticResource Blue700}"/>
    <SolidColorBrush x:Key="Blue600Brush" Color="{StaticResource Blue600}"/>
    <SolidColorBrush x:Key="Blue500Brush" Color="{StaticResource Blue500}"/>
    <SolidColorBrush x:Key="Blue400Brush" Color="{StaticResource Blue400}"/>
    <SolidColorBrush x:Key="Blue200Brush" Color="{StaticResource Blue200}"/>
    <SolidColorBrush x:Key="Blue100Brush" Color="{StaticResource Blue100}"/>
    <SolidColorBrush x:Key="Blue050Brush" Color="{StaticResource Blue050}"/>
    <SolidColorBrush x:Key="Gray800Brush" Color="{StaticResource Gray800}"/>
    <SolidColorBrush x:Key="Gray700Brush" Color="{StaticResource Gray700}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray050Brush" Color="{StaticResource Gray050}"/>
    <SolidColorBrush x:Key="WhiteBrush"   Color="#1E1E1E"/>
    <SolidColorBrush x:Key="RedAccentBrush"   Color="{StaticResource RedAccent}"/>
    <SolidColorBrush x:Key="GreenAccentBrush" Color="{StaticResource GreenAccent}"/>
    <SolidColorBrush x:Key="GreenLightBrush"  Color="{StaticResource GreenLight}"/>
    <SolidColorBrush x:Key="AmberAccentBrush" Color="{StaticResource AmberAccent}"/>

</ResourceDictionary>
