<Window x:Class="FileExplorerCS.SplitPdfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split / Extract PDF"
        Height="260"
        Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F8FF">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="14" Foreground="#1976D2" FontWeight="SemiBold" Text="Choose Split or Extraction Mode" />

        <Border Grid.Row="2" BorderBrush="#90CAF9" BorderThickness="1" CornerRadius="8" Background="White" Padding="14">
            <StackPanel>
                <!-- Split Evenly Option -->
                <RadioButton x:Name="SplitEvenlyRadio" GroupName="SplitMode" IsChecked="True" Content="Split evenly" FontSize="12" FontWeight="Medium" Checked="OnSplitModeChanged"/>
                <StackPanel x:Name="SplitEvenlyPanel" Orientation="Horizontal" Margin="20,6,0,12">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="#374151" Text="Pages per split: " />
                    <TextBox x:Name="PagesPerSplitTextBox" 
                             Width="60" 
                             Height="26" 
                             VerticalContentAlignment="Center" 
                             Text="1" 
                             FontSize="12"
                             Background="White" 
                             BorderBrush="#CED4DA" 
                             BorderThickness="1" 
                             Padding="6,0" />
                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" Foreground="#546E7A" Text="(1 = split each page separately)" />
                </StackPanel>

                <!-- Extract Range Option -->
                <RadioButton x:Name="ExtractRangeRadio" GroupName="SplitMode" Content="Extract page range(s)" FontSize="12" FontWeight="Medium" Checked="OnSplitModeChanged"/>
                <StackPanel x:Name="ExtractRangePanel" Orientation="Horizontal" Margin="20,6,0,0" IsEnabled="False" Opacity="0.5">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="#374151" Text="Page range: " />
                    <TextBox x:Name="PageRangeTextBox" 
                             Width="120" 
                             Height="26" 
                             VerticalContentAlignment="Center" 
                             Text="" 
                             FontSize="12"
                             Background="White" 
                             BorderBrush="#CED4DA" 
                             BorderThickness="1" 
                             Padding="6,0" />
                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" Foreground="#546E7A" Text="(e.g. 1-3, 5, 7-10)" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Width="80" Height="34" Margin="0,0,10,0" Click="CancelButton_OnClick"
                    Background="#E3F2FD" BorderBrush="#90CAF9" Foreground="#1976D2" FontSize="12" FontWeight="Medium" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                             BorderBrush="{TemplateBinding BorderBrush}" 
                                             BorderThickness="1" 
                                             CornerRadius="5"
                                             Padding="10,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>Cancel
            </Button>
            <Button x:Name="OKButton" Width="80" Height="34" Click="OKButton_OnClick"
                    Background="#1976D2" BorderBrush="#1565C0" Foreground="White" FontSize="12" FontWeight="Medium" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                             BorderBrush="{TemplateBinding BorderBrush}" 
                                             BorderThickness="1" 
                                             CornerRadius="5"
                                             Padding="10,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>OK
            </Button>
        </StackPanel>
    </Grid>
</Window>
