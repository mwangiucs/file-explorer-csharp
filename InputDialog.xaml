<Window x:Class="FileExplorerCS.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Tag" Height="150" Width="300" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock x:Name="PromptText" Text="Enter new tag name:" Grid.Row="0" Margin="0,0,0,8" />
        <TextBox x:Name="InputTextBox" Grid.Row="1" Height="24" VerticalContentAlignment="Center" KeyDown="InputTextBox_KeyDown" />
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="70" Margin="0,0,8,0" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="70" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
