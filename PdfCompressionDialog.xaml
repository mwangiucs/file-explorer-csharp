<Window x:Class="FileExplorerCS.PdfCompressionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compress PDF"
        Height="340"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F8FF">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="14" Foreground="#1976D2" FontWeight="SemiBold" Text="Configure PDF Compression" />

        <Border Grid.Row="2" BorderBrush="#90CAF9" BorderThickness="1" CornerRadius="8" Background="White" Padding="14">
            <StackPanel>
                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8" Text="Compression Level:" />
                
                <RadioButton x:Name="LowRadio" GroupName="Level" IsChecked="True" Margin="0,0,0,6">
                    <StackPanel Margin="6,0,0,0">
                        <TextBlock FontSize="12" FontWeight="Medium" Foreground="#111827" Text="Low Compression (High Quality)" />
                        <TextBlock FontSize="10" Foreground="#6B7280" Text="Image quality: 85%, Max resolution: 2000px" />
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="MediumRadio" GroupName="Level" Margin="0,0,0,6">
                    <StackPanel Margin="6,0,0,0">
                        <TextBlock FontSize="12" FontWeight="Medium" Foreground="#111827" Text="Medium Compression (Balanced)" />
                        <TextBlock FontSize="10" Foreground="#6B7280" Text="Image quality: 60%, Max resolution: 1200px" />
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="HighRadio" GroupName="Level" Margin="0,0,0,12">
                    <StackPanel Margin="6,0,0,0">
                        <TextBlock FontSize="12" FontWeight="Medium" Foreground="#111827" Text="High Compression (Smallest File)" />
                        <TextBlock FontSize="10" Foreground="#6B7280" Text="Image quality: 35%, Max resolution: 800px" />
                    </StackPanel>
                </RadioButton>

                <Separator Background="#E5E7EB" Height="1" Margin="0,0,0,10"/>

                <CheckBox x:Name="GhostscriptCheck" IsChecked="True" Content="Try Ghostscript engine first if installed" FontSize="11" Foreground="#374151" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Width="80" Height="34" Margin="0,0,10,0" Click="CancelButton_OnClick"
                    Background="#E3F2FD" BorderBrush="#90CAF9" Foreground="#1976D2" FontSize="12" FontWeight="Medium" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                             BorderBrush="{TemplateBinding BorderBrush}" 
                                             BorderThickness="1" 
                                             CornerRadius="5"
                                             Padding="10,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>Cancel
            </Button>
            <Button x:Name="CompressButton" Width="90" Height="34" Click="CompressButton_OnClick"
                    Background="#1976D2" BorderBrush="#1565C0" Foreground="White" FontSize="12" FontWeight="Medium" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                             BorderBrush="{TemplateBinding BorderBrush}" 
                                             BorderThickness="1" 
                                             CornerRadius="5"
                                             Padding="10,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>Compress
            </Button>
        </StackPanel>
    </Grid>
</Window>
