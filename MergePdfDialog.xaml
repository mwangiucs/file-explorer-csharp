<Window x:Class="FileExplorerCS.MergePdfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Merge PDFs - Arrange Pages &amp; Merge"
        Height="550"
        Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F0F8FF">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock FontSize="14" Foreground="#1976D2" FontWeight="SemiBold" Text="Arrange pages in merge order" />
                <TextBlock FontSize="11" Foreground="#546E7A" Text="Drag and drop thumbnails to reorder pages. Selected pages can be removed." />
            </StackPanel>
            <Button Grid.Column="1" x:Name="AddFilesButton" Content="➕ Add PDF..." Click="AddFilesButton_Click" Height="32" Padding="10,0" 
                    Background="#E3F2FD" BorderBrush="#90CAF9" Foreground="#1976D2" FontWeight="Medium" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                             BorderBrush="{TemplateBinding BorderBrush}" 
                                             BorderThickness="1" 
                                             CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
        
        <Border Grid.Row="2" BorderBrush="#90CAF9" BorderThickness="1" CornerRadius="8" Background="White" Padding="8">
            <ListView x:Name="PageListView" 
                      Background="White"
                      BorderThickness="0"
                      SelectionMode="Extended"
                      AllowDrop="True"
                      Drop="PageListView_Drop"
                      DragOver="PageListView_DragOver"
                      PreviewMouseLeftButtonDown="PageListView_PreviewMouseLeftButtonDown"
                      MouseMove="PageListView_MouseMove"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#90CAF9" BorderThickness="1" CornerRadius="6" Background="White" Margin="6" Padding="6" Width="125" Height="175" ToolTip="{Binding SourceFileName}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Background="#F8F9FA">
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="2"/>
                                    <Button VerticalAlignment="Top" HorizontalAlignment="Right" Width="18" Height="18" Background="#FFEAEA" BorderBrush="#FFC1C1" Command="{Binding DataContext.RemovePageCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" ToolTip="Remove Page" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="9">
                                                    <TextBlock Text="×" Foreground="#A32D2D" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                
                                <TextBlock Grid.Row="1" Text="{Binding SourceFileName}" FontSize="10" FontWeight="SemiBold" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Text="{Binding PageLabel}" FontSize="9" Foreground="#1976D2" TextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="MoveLeftButton" Content="◀ Move Left" Click="MoveLeftButton_Click" Width="90" Height="36" Margin="0,0,6,0" 
                        Background="#E3F2FD" BorderBrush="#90CAF9" Foreground="#1976D2" FontSize="12" FontWeight="Medium" Cursor="Hand"/>
                <Button x:Name="MoveRightButton" Content="Move Right ▶" Click="MoveRightButton_Click" Width="95" Height="36" Margin="0,0,6,0" 
                        Background="#E3F2FD" BorderBrush="#90CAF9" Foreground="#1976D2" FontSize="12" FontWeight="Medium" Cursor="Hand"/>
                <Button x:Name="RemoveSelectedButton" Content="🗑️ Remove" Click="RemoveSelectedButton_Click" Width="90" Height="36" 
                        Background="#FCEBEB" BorderBrush="#F09595" Foreground="#A32D2D" FontSize="12" FontWeight="Medium" Cursor="Hand"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="36" Margin="0,0,8,0" Click="CancelButton_OnClick"
                        Background="#E3F2FD" BorderBrush="#90CAF9" Foreground="#1976D2" FontSize="12" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                 BorderBrush="{TemplateBinding BorderBrush}" 
                                                 BorderThickness="1" 
                                                 CornerRadius="5"
                                                 Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="OKButton" Content="Merge" Width="80" Height="36" Click="OKButton_OnClick"
                        Background="#1976D2" BorderBrush="#1565C0" Foreground="White" FontSize="12" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                 BorderBrush="{TemplateBinding BorderBrush}" 
                                                 BorderThickness="1" 
                                                 CornerRadius="5"
                                                 Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
