<Window x:Class="FileExplorerCS.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:FileExplorerCS"

        mc:Ignorable="d"

        Title="FileExplorer"

        Height="780" Width="1200"

        MinHeight="580" MinWidth="900"

        WindowStyle="None"

        AllowsTransparency="False"

        Background="{DynamicResource Blue800Brush}"

        Loaded="Window_OnLoaded"

        KeyDown="Window_OnKeyDown"

        StateChanged="Window_StateChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="6"
                      CornerRadius="10"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>



    <Window.Resources>



        <!-- ── Color Palette ─────────────────────────────────────── -->

        <Color x:Key="Blue900">#042C53</Color>

        <Color x:Key="Blue800">#0C447C</Color>

        <Color x:Key="Blue700">#0E4D8A</Color>

        <Color x:Key="Blue600">#185FA5</Color>

        <Color x:Key="Blue500">#2470B8</Color>

        <Color x:Key="Blue400">#378ADD</Color>

        <Color x:Key="Blue200">#85B7EB</Color>

        <Color x:Key="Blue100">#B5D4F4</Color>

        <Color x:Key="Blue050">#E6F1FB</Color>

        <Color x:Key="Gray800">#343A40</Color>

        <Color x:Key="Gray700">#495057</Color>

        <Color x:Key="Gray600">#6C757D</Color>

        <Color x:Key="Gray500">#ADB5BD</Color>

        <Color x:Key="Gray400">#CED4DA</Color>

        <Color x:Key="Gray300">#DEE2E6</Color>

        <Color x:Key="Gray200">#E9ECEF</Color>

        <Color x:Key="Gray100">#F1F3F5</Color>

        <Color x:Key="Gray050">#F8F9FA</Color>

        <Color x:Key="RedAccent">#E24B4A</Color>

        <Color x:Key="GreenAccent">#1D9E75</Color>

        <Color x:Key="GreenLight">#EAF3DE</Color>

        <Color x:Key="AmberAccent">#BA7517</Color>



        <SolidColorBrush x:Key="Blue900Brush" Color="{StaticResource Blue900}"/>

        <SolidColorBrush x:Key="Blue800Brush" Color="{StaticResource Blue800}"/>

        <SolidColorBrush x:Key="Blue700Brush" Color="{StaticResource Blue700}"/>

        <SolidColorBrush x:Key="Blue600Brush" Color="{StaticResource Blue600}"/>

        <SolidColorBrush x:Key="Blue500Brush" Color="{StaticResource Blue500}"/>

        <SolidColorBrush x:Key="Blue400Brush" Color="{StaticResource Blue400}"/>

        <SolidColorBrush x:Key="Blue200Brush" Color="{StaticResource Blue200}"/>

        <SolidColorBrush x:Key="Blue100Brush" Color="{StaticResource Blue100}"/>

        <SolidColorBrush x:Key="Blue050Brush" Color="{StaticResource Blue050}"/>

        <SolidColorBrush x:Key="Gray800Brush" Color="{StaticResource Gray800}"/>

        <SolidColorBrush x:Key="Gray700Brush" Color="{StaticResource Gray700}"/>

        <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>

        <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>

        <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>

        <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>

        <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>

        <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>

        <SolidColorBrush x:Key="Gray050Brush" Color="{StaticResource Gray050}"/>

        <SolidColorBrush x:Key="WhiteBrush"   Color="White"/>

        <SolidColorBrush x:Key="RedAccentBrush"   Color="{StaticResource RedAccent}"/>

        <SolidColorBrush x:Key="GreenAccentBrush" Color="{StaticResource GreenAccent}"/>

        <SolidColorBrush x:Key="GreenLightBrush"  Color="{StaticResource GreenLight}"/>

        <SolidColorBrush x:Key="AmberAccentBrush" Color="{StaticResource AmberAccent}"/>



        <!-- ── Typography ───────────────────────────────────────── -->

        <Style x:Key="BaseText" TargetType="TextBlock">

            <Setter Property="FontFamily"  Value="Segoe UI"/>

            <Setter Property="FontSize"    Value="13"/>

            <Setter Property="Foreground"  Value="{StaticResource Gray800Brush}"/>

            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>

        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock" BasedOn="{StaticResource BaseText}">

            <Setter Property="FontSize"   Value="10"/>

            <Setter Property="Foreground" Value="{StaticResource Gray600Brush}"/>

            <Setter Property="FontWeight" Value="Medium"/>

        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock" BasedOn="{StaticResource BaseText}">

            <Setter Property="FontSize"   Value="10"/>

            <Setter Property="Foreground" Value="{StaticResource Gray500Brush}"/>

            <Setter Property="FontWeight" Value="Medium"/>

            <Setter Property="Margin"     Value="0,10,0,4"/>

        </Style>



        <!-- ── Scrollbar ────────────────────────────────────────── -->

        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">

            <Setter Property="Width" Value="6"/>

            <Setter Property="Background" Value="Transparent"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="ScrollBar">

                        <Grid>

                            <Track x:Name="PART_Track" IsDirectionReversed="True">

                                <Track.Thumb>

                                    <Thumb>

                                        <Thumb.Template>

                                            <ControlTemplate TargetType="Thumb">

                                                <Border Background="{StaticResource Gray400Brush}"

                                                        CornerRadius="3" Margin="1"/>

                                            </ControlTemplate>

                                        </Thumb.Template>

                                    </Thumb>

                                </Track.Thumb>

                            </Track>

                        </Grid>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style TargetType="ScrollViewer">

            <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>

            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>

        </Style>



        <!-- ── Ribbon Button ────────────────────────────────────── -->

        <Style x:Key="RibbonButton" TargetType="Button">

            <Setter Property="Background"       Value="#22FFFFFF"/>

            <Setter Property="BorderBrush"      Value="#33FFFFFF"/>

            <Setter Property="BorderThickness"  Value="0.5"/>

            <Setter Property="Foreground"       Value="White"/>

            <Setter Property="Padding"          Value="10,6"/>

            <Setter Property="MinWidth"         Value="52"/>

            <Setter Property="Cursor"           Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="{TemplateBinding BorderThickness}"

                                CornerRadius="5" Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Background" Value="#44FFFFFF"/>

                                <Setter Property="BorderBrush" Value="#66FFFFFF"/>

                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">

                                <Setter Property="Background" Value="#55FFFFFF"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ── Ribbon Toggle (tab) ───────────────────────────────── -->

        <Style x:Key="RibbonTab" TargetType="RadioButton">

            <Setter Property="Background"      Value="Transparent"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Foreground"      Value="#AAFFFFFF"/>

            <Setter Property="Padding"         Value="14,7"/>

            <Setter Property="FontSize"        Value="12"/>

            <Setter Property="Cursor"          Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="RadioButton">

                        <Border x:Name="Bd" Background="{TemplateBinding Background}"

                                CornerRadius="5,5,0,0" Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Foreground"            Value="White"/>

                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>

                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">

                                <Setter Property="Foreground"            Value="White"/>

                                <Setter Property="FontWeight"            Value="Medium"/>

                                <Setter TargetName="Bd" Property="Background"

                                        Value="{StaticResource Blue700Brush}"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ── Left Panel Tab ───────────────────────────────────── -->

        <Style x:Key="PanelTab" TargetType="RadioButton">

            <Setter Property="Background"      Value="Transparent"/>

            <Setter Property="BorderBrush"     Value="Transparent"/>

            <Setter Property="BorderThickness" Value="0,0,0,2"/>

            <Setter Property="Foreground"      Value="{StaticResource Gray600Brush}"/>

            <Setter Property="Padding"         Value="8,8"/>

            <Setter Property="FontSize"        Value="11"/>

            <Setter Property="Cursor"          Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="RadioButton">

                        <Border x:Name="Bd" Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="{TemplateBinding BorderThickness}"

                                Padding="{TemplateBinding Padding}">

                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">

                                <ContentPresenter HorizontalAlignment="Center"/>

                            </StackPanel>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Foreground" Value="{StaticResource Blue600Brush}"/>

                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">

                                <Setter Property="Foreground"             Value="{StaticResource Blue600Brush}"/>

                                <Setter Property="FontWeight"             Value="Medium"/>

                                <Setter TargetName="Bd" Property="BorderBrush"

                                        Value="{StaticResource Blue400Brush}"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ── Nav Button (Back/Fwd/Up) ─────────────────────────── -->

        <Style x:Key="NavButton" TargetType="Button">

            <Setter Property="Background"       Value="#22FFFFFF"/>

            <Setter Property="BorderBrush"      Value="#33FFFFFF"/>

            <Setter Property="BorderThickness"  Value="0.5"/>

            <Setter Property="Foreground"       Value="White"/>

            <Setter Property="Width"  Value="30"/>

            <Setter Property="Height" Value="26"/>

            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="{TemplateBinding BorderThickness}"

                                CornerRadius="5">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Background" Value="#44FFFFFF"/>

                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">

                                <Setter Property="Opacity" Value="0.35"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ── TextBox base ─────────────────────────────────────── -->

        <Style x:Key="ModernTextBox" TargetType="TextBox">

            <Setter Property="Background"      Value="White"/>

            <Setter Property="BorderBrush"     Value="{StaticResource Gray300Brush}"/>

            <Setter Property="BorderThickness" Value="0.5"/>

            <Setter Property="Foreground"      Value="{StaticResource Gray800Brush}"/>

            <Setter Property="FontFamily"      Value="Segoe UI"/>

            <Setter Property="FontSize"        Value="11"/>

            <Setter Property="Padding"         Value="7,3"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="TextBox">

                        <Border Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="{TemplateBinding BorderThickness}"

                                CornerRadius="5">

                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"

                                          VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsFocused" Value="True">

                                <Setter Property="BorderBrush" Value="{StaticResource Blue400Brush}"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- Address bar textbox (white-on-blue) -->

        <Style x:Key="AddressTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">

            <Setter Property="Background"      Value="#22FFFFFF"/>

            <Setter Property="BorderBrush"     Value="#33FFFFFF"/>

            <Setter Property="Foreground"      Value="White"/>

            <Setter Property="FontSize"        Value="11"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="TextBox">

                        <Border Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="0.5" CornerRadius="5">

                            <ScrollViewer x:Name="PART_ContentHost" Margin="8,3"

                                          VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsFocused" Value="True">

                                <Setter Property="Background" Value="#33FFFFFF"/>

                                <Setter Property="BorderBrush" Value="#66FFFFFF"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ── ComboBox ──────────────────────────────────────────── -->

        <Style x:Key="ModernCombo" TargetType="ComboBox">

            <Setter Property="Background"       Value="White"/>

            <Setter Property="BorderBrush"      Value="{StaticResource Gray300Brush}"/>

            <Setter Property="BorderThickness"  Value="0.5"/>

            <Setter Property="Foreground"       Value="{StaticResource Gray800Brush}"/>

            <Setter Property="FontFamily"       Value="Segoe UI"/>

            <Setter Property="FontSize"         Value="12"/>

            <Setter Property="Padding"          Value="7,5"/>

            <Setter Property="Height"           Value="30"/>

        </Style>



        <!-- ── DatePicker ───────────────────────────────────────── -->

        <Style x:Key="ModernDatePicker" TargetType="DatePicker">

            <Setter Property="Background"      Value="White"/>

            <Setter Property="BorderBrush"     Value="{StaticResource Gray300Brush}"/>

            <Setter Property="BorderThickness" Value="0.5"/>

            <Setter Property="FontFamily"      Value="Segoe UI"/>

            <Setter Property="FontSize"        Value="12"/>

            <Setter Property="Height"          Value="30"/>

        </Style>



        <!-- ── CheckBox ─────────────────────────────────────────── -->

        <Style x:Key="ModernCheck" TargetType="CheckBox">

            <Setter Property="FontFamily" Value="Segoe UI"/>

            <Setter Property="FontSize"   Value="12"/>

            <Setter Property="Foreground" Value="{StaticResource Gray700Brush}"/>

            <Setter Property="Cursor"     Value="Hand"/>

            <Setter Property="Margin"     Value="0,2"/>

        </Style>



        <!-- ── RadioButton (inline) ──────────────────────────────── -->

        <Style x:Key="ModernRadio" TargetType="RadioButton">

            <Setter Property="FontFamily" Value="Segoe UI"/>

            <Setter Property="FontSize"   Value="12"/>

            <Setter Property="Foreground" Value="{StaticResource Gray700Brush}"/>

            <Setter Property="Cursor"     Value="Hand"/>

            <Setter Property="Margin"     Value="0,2"/>

        </Style>



        <!-- ── Action Button (blue fill) ───────────────────────── -->

        <Style x:Key="ActionButton" TargetType="Button">

            <Setter Property="Background"       Value="{StaticResource Blue600Brush}"/>

            <Setter Property="Foreground"       Value="White"/>

            <Setter Property="BorderThickness"  Value="0"/>

            <Setter Property="FontFamily"       Value="Segoe UI"/>

            <Setter Property="FontSize"         Value="12"/>

            <Setter Property="FontWeight"       Value="Medium"/>

            <Setter Property="Padding"          Value="12,7"/>

            <Setter Property="Cursor"           Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"

                                CornerRadius="5" Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Background" Value="{StaticResource Blue700Brush}"/>

                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">

                                <Setter Property="Background" Value="{StaticResource Blue800Brush}"/>

                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">

                                <Setter Property="Opacity" Value="0.4"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ── Ghost Button (outlined) ──────────────────────────── -->

        <Style x:Key="GhostButton" TargetType="Button">

            <Setter Property="Background"       Value="Transparent"/>

            <Setter Property="BorderBrush"      Value="{StaticResource Gray300Brush}"/>

            <Setter Property="BorderThickness"  Value="0.5"/>

            <Setter Property="Foreground"       Value="{StaticResource Gray700Brush}"/>

            <Setter Property="FontFamily"       Value="Segoe UI"/>

            <Setter Property="FontSize"         Value="12"/>

            <Setter Property="Padding"          Value="10,5"/>

            <Setter Property="Cursor"           Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="{TemplateBinding BorderThickness}"

                                CornerRadius="5" Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Background"   Value="{StaticResource Blue050Brush}"/>

                                <Setter Property="BorderBrush"  Value="{StaticResource Blue200Brush}"/>

                                <Setter Property="Foreground"   Value="{StaticResource Blue600Brush}"/>

                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">

                                <Setter Property="Background" Value="{StaticResource Blue100Brush}"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ── TreeViewItem ─────────────────────────────────────── -->

        <Style TargetType="TreeViewItem">

            <Setter Property="FontFamily"  Value="Segoe UI"/>

            <Setter Property="FontSize"    Value="12"/>

            <Setter Property="Foreground"  Value="{StaticResource Gray700Brush}"/>

            <Setter Property="Padding"     Value="4,4"/>

            <Setter Property="Cursor"      Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="TreeViewItem">

                        <Grid>

                            <Grid.RowDefinitions>

                                <RowDefinition Height="Auto"/>

                                <RowDefinition/>

                            </Grid.RowDefinitions>

                            <Border x:Name="Bd" Grid.Row="0"

                                    Background="{TemplateBinding Background}"

                                    CornerRadius="5" Padding="4,4">

                                <Grid>

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="14"/>

                                        <ColumnDefinition/>

                                    </Grid.ColumnDefinitions>

                                    <ToggleButton x:Name="Expander" Grid.Column="0"

                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"

                                                  Style="{x:Null}" Cursor="Hand"

                                                  Background="Transparent" BorderThickness="0"

                                                  Width="12" Height="12" Focusable="False">

                                        <ToggleButton.Template>

                                            <ControlTemplate TargetType="ToggleButton">

                                                <TextBlock x:Name="Arrow" Text="▶"

                                                           FontSize="8" Foreground="{StaticResource Gray500Brush}"

                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                <ControlTemplate.Triggers>

                                                    <Trigger Property="IsChecked" Value="True">

                                                        <Setter TargetName="Arrow" Property="Text" Value="▼"/>

                                                    </Trigger>

                                                </ControlTemplate.Triggers>

                                            </ControlTemplate>

                                        </ToggleButton.Template>

                                    </ToggleButton>

                                    <ContentPresenter x:Name="PART_Header" Grid.Column="1"

                                                      ContentSource="Header"

                                                      VerticalAlignment="Center"/>

                                </Grid>

                            </Border>

                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="16,0,0,0"/>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="HasItems" Value="False">

                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>

                            </Trigger>

                            <Trigger Property="IsExpanded" Value="False">

                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>

                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Blue050Brush}"/>

                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">

                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Blue100Brush}"/>

                                <Setter Property="Foreground" Value="{StaticResource Blue800Brush}"/>

                                <Setter Property="FontWeight" Value="Medium"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ── ListView ─────────────────────────────────────────── -->

        <Style TargetType="ListView">

            <Setter Property="Background"      Value="White"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="FontFamily"      Value="Segoe UI"/>

            <Setter Property="FontSize"        Value="12"/>

            <Setter Property="SelectionMode"   Value="Extended"/>

            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>

        </Style>



        <!-- ── ListViewItem ──────────────────────────────────────── -->

        <Style TargetType="ListViewItem">

            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

            <Setter Property="Padding"                    Value="0"/>

            <Setter Property="BorderThickness"            Value="0"/>

            <Setter Property="Cursor"                     Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="ListViewItem">

                        <Border x:Name="Bd" Background="Transparent"

                                CornerRadius="5" Margin="4,1">

                            <ContentPresenter/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Blue050Brush}"/>

                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">

                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Blue100Brush}"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="FileListItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="5" Margin="4,1">
                            <GridViewRowPresenter Columns="{TemplateBinding GridView.ColumnCollection}" 
                                                  Content="{TemplateBinding Content}"
                                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Blue050Brush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Blue100Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!-- ── GridViewColumnHeader ──────────────────────────────── -->

        <Style TargetType="GridViewColumnHeader">

            <Setter Property="Background"      Value="{StaticResource Gray050Brush}"/>

            <Setter Property="Foreground"      Value="{StaticResource Gray600Brush}"/>

            <Setter Property="FontFamily"      Value="Segoe UI"/>

            <Setter Property="FontSize"        Value="10"/>

            <Setter Property="FontWeight"      Value="Medium"/>

            <Setter Property="BorderBrush"     Value="{StaticResource Gray300Brush}"/>

            <Setter Property="BorderThickness" Value="0,0,0,0.5"/>

            <Setter Property="Padding"         Value="10,7"/>

            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="GridViewColumnHeader">

                        <Grid>

                            <Border Background="{TemplateBinding Background}"

                                    BorderBrush="{TemplateBinding BorderBrush}"

                                    BorderThickness="{TemplateBinding BorderThickness}"

                                    Padding="{TemplateBinding Padding}">

                                <TextBlock Text="{TemplateBinding Content}"

                                           Foreground="{TemplateBinding Foreground}"

                                           FontFamily="{TemplateBinding FontFamily}"

                                           FontSize="{TemplateBinding FontSize}"

                                           FontWeight="{TemplateBinding FontWeight}"/>

                            </Border>

                            <Thumb x:Name="PART_HeaderGripper"

                                   HorizontalAlignment="Right"

                                   Width="10"

                                   Margin="0,0,-5,0"

                                   Background="Transparent"

                                   Cursor="SizeWE">

                                <Thumb.Template>

                                    <ControlTemplate TargetType="Thumb">

                                        <Border Background="Transparent" Width="10"/>

                                    </ControlTemplate>

                                </Thumb.Template>

                            </Thumb>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Foreground" Value="{StaticResource Blue600Brush}"/>

                                <Setter Property="Background" Value="{StaticResource Blue050Brush}"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ── Tag pill ──────────────────────────────────────────── -->

        <Style x:Key="TagPill" TargetType="Border">

            <Setter Property="Background"       Value="{StaticResource Blue050Brush}"/>

            <Setter Property="BorderBrush"      Value="{StaticResource Blue100Brush}"/>

            <Setter Property="BorderThickness"  Value="0.5"/>

            <Setter Property="CornerRadius"     Value="8"/>

            <Setter Property="Padding"          Value="5,1"/>

        </Style>



        <!-- ── Section divider ───────────────────────────────────── -->

        <Style x:Key="Divider" TargetType="Separator">

            <Setter Property="Background"   Value="{StaticResource Gray300Brush}"/>

            <Setter Property="Height"       Value="0.5"/>

            <Setter Property="Margin"       Value="0,4"/>

        </Style>



        <!-- ── Inspector tab button ──────────────────────────────── -->

        <Style x:Key="InspectorTab" TargetType="RadioButton" BasedOn="{StaticResource PanelTab}">

            <Setter Property="FontSize" Value="12"/>

            <Setter Property="Padding"  Value="10,7"/>

        </Style>



        <!-- ── Zoom slider ───────────────────────────────────────── -->

        <Style x:Key="ZoomSlider" TargetType="Slider">

            <Setter Property="Minimum"     Value="25"/>

            <Setter Property="Maximum"     Value="400"/>

            <Setter Property="Value"       Value="100"/>

            <Setter Property="SmallChange" Value="5"/>

            <Setter Property="LargeChange" Value="25"/>

            <Setter Property="TickFrequency" Value="25"/>

            <Setter Property="IsSnapToTickEnabled" Value="False"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Slider">

                        <Grid>

                            <Track x:Name="PART_Track">

                                <Track.DecreaseRepeatButton>

                                    <RepeatButton Command="Slider.DecreaseLarge">

                                        <RepeatButton.Template>

                                            <ControlTemplate TargetType="RepeatButton">

                                                <Border Background="{StaticResource Blue400Brush}" Height="3" CornerRadius="1.5"/>

                                            </ControlTemplate>

                                        </RepeatButton.Template>

                                    </RepeatButton>

                                </Track.DecreaseRepeatButton>

                                <Track.IncreaseRepeatButton>

                                    <RepeatButton Command="Slider.IncreaseLarge">

                                        <RepeatButton.Template>

                                            <ControlTemplate TargetType="RepeatButton">

                                                <Border Background="{StaticResource Gray300Brush}" Height="3" CornerRadius="1.5"/>

                                            </ControlTemplate>

                                        </RepeatButton.Template>

                                    </RepeatButton>

                                </Track.IncreaseRepeatButton>

                                <Track.Thumb>

                                    <Thumb>

                                        <Thumb.Template>

                                            <ControlTemplate TargetType="Thumb">

                                                <Ellipse Width="14" Height="14"

                                                         Fill="{StaticResource Blue600Brush}"

                                                         Stroke="White" StrokeThickness="2"/>

                                            </ControlTemplate>

                                        </Thumb.Template>

                                    </Thumb>

                                </Track.Thumb>

                            </Track>

                        </Grid>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:StringToVisibilityConverter x:Key="StringToVis"/>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding Tag}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1AFFFFFF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#33FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#F1707A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Icon Gradients -->
        <LinearGradientBrush x:Key="FolderBackBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFE5A3" Offset="0.0"/>
            <GradientStop Color="#F5B041" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="FolderFrontBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FAD7A0" Offset="0.0"/>
            <GradientStop Color="#F39C12" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PdfBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF6B6B" Offset="0.0"/>
            <GradientStop Color="#C0392B" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ImageBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B59B6" Offset="0.0"/>
            <GradientStop Color="#8E44AD" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="TextBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#5DADE2" Offset="0.0"/>
            <GradientStop Color="#2980B9" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CodeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#48C9B0" Offset="0.0"/>
            <GradientStop Color="#16A085" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ArchiveBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EB984E" Offset="0.0"/>
            <GradientStop Color="#D35400" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AudioBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EC407A" Offset="0.0"/>
            <GradientStop Color="#AD1457" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="VideoBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF7043" Offset="0.0"/>
            <GradientStop Color="#D84315" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ExecBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#78909C" Offset="0.0"/>
            <GradientStop Color="#37474F" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GenericFileBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#BDC3C7" Offset="0.0"/>
            <GradientStop Color="#95A5A6" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Vector Icon Templates -->
        <ControlTemplate x:Key="FolderIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M2,4 C2,2.9 2.9,2 4,2 L9,2 C9.6,2 10.1,2.2 10.5,2.6 L12.4,4.5 C12.8,4.9 13.3,5 13.9,5 L20,5 C21.1,5 22,5.9 22,7 L22,19 C22,20.1 21.1,21 20,21 L4,21 C2.9,21 2,20.1 2,19 Z" Fill="{StaticResource FolderBackBrush}"/>
                    <Path Data="M2,8.5 C2,7.7 2.7,7 3.5,7 L20.5,7 C21.3,7 22,7.7 22,8.5 L22,19 C22,20.1 21.1,21 20,21 L4,21 C2.9,21 2,20.1 2,19 Z" Fill="{StaticResource FolderFrontBrush}">
                        <Path.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Direction="90" Color="#20000000"/>
                        </Path.Effect>
                    </Path>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="PdfIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M4,2 C4,0.9 4.9,0 6,0 L14,0 L20,6 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 Z" Fill="{StaticResource PdfBrush}"/>
                    <Path Data="M14,0 L14,6 L20,6 Z" Fill="#30FFFFFF"/>
                    <Path Data="M7,12 L8.5,12 C9.3,12 10,11.3 10,10.5 C10,9.7 9.3,9 8.5,9 L7,9 V15 M8.5,10.5 L8.5,10.5 H7 V10.5 H8.5 Z" Stroke="White" StrokeThickness="1" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <Path Data="M11,9 V15 H12.5 C13.8,15 15,13.8 15,12.5 C15,11.2 13.8,9 12.5,9 H11 Z M12.5,14 H12 V10 H12.5 C13,10 13.5,10.5 13.5,11.5 C13.5,12.5 13,14 12.5,14 Z" Stroke="White" StrokeThickness="1" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <Path Data="M16,9 H19 M16,11.5 H18 M16,9 V15" Stroke="White" StrokeThickness="1" StrokeStartLineCap="Round"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="ImageIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M4,2 C4,0.9 4.9,0 6,0 L14,0 L20,6 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 Z" Fill="{StaticResource ImageBrush}"/>
                    <Path Data="M14,0 L14,6 L20,6 Z" Fill="#30FFFFFF"/>
                    <Path Data="M7,17 L11,11 L14,15 L17,10 L19,13 L19,17 Z" Fill="White" Opacity="0.6"/>
                    <Ellipse Canvas.Left="15" Canvas.Top="5" Width="2.5" Height="2.5" Fill="White" Opacity="0.8"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="TextIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M4,2 C4,0.9 4.9,0 6,0 L14,0 L20,6 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 Z" Fill="{StaticResource TextBrush}"/>
                    <Path Data="M14,0 L14,6 L20,6 Z" Fill="#30FFFFFF"/>
                    <Path Data="M8,10 H16 M8,13 H16 M8,16 H14" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.7"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="CodeIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M4,2 C4,0.9 4.9,0 6,0 L14,0 L20,6 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 Z" Fill="{StaticResource CodeBrush}"/>
                    <Path Data="M14,0 L14,6 L20,6 Z" Fill="#30FFFFFF"/>
                    <Path Data="M9,11 L7,13 L9,15 M15,11 L17,13 L15,15" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.8"/>
                    <Path Data="M13,10 L11,16" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.8"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="ArchiveIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M4,2 C4,0.9 4.9,0 6,0 L14,0 L20,6 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 Z" Fill="{StaticResource ArchiveBrush}"/>
                    <Path Data="M14,0 L14,6 L20,6 Z" Fill="#30FFFFFF"/>
                    <Path Data="M11,8 H13 M11,10 H13 M11,12 H13 M11,14 H13 M11,16 H13" Stroke="White" StrokeThickness="1.5"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="AudioIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M4,2 C4,0.9 4.9,0 6,0 L14,0 L20,6 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 Z" Fill="{StaticResource AudioBrush}"/>
                    <Path Data="M14,0 L14,6 L20,6 Z" Fill="#30FFFFFF"/>
                    <Path Data="M10,14 V9 C10,9 14,8 14,10 V14" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="{x:Null}"/>
                    <Ellipse Canvas.Left="8" Canvas.Top="13" Width="3" Height="2" Fill="White"/>
                    <Ellipse Canvas.Left="12" Canvas.Top="12" Width="3" Height="2" Fill="White"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="VideoIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M4,2 C4,0.9 4.9,0 6,0 L14,0 L20,6 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 Z" Fill="{StaticResource VideoBrush}"/>
                    <Path Data="M14,0 L14,6 L20,6 Z" Fill="#30FFFFFF"/>
                    <Path Data="M10,9 L15,12 L10,15 Z" Fill="White" Opacity="0.9"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="ExecIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M4,2 C4,0.9 4.9,0 6,0 L14,0 L20,6 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 Z" Fill="{StaticResource ExecBrush}"/>
                    <Path Data="M14,0 L14,6 L20,6 Z" Fill="#30FFFFFF"/>
                    <Path Data="M8,11 L10,13 L8,15" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" Fill="{x:Null}"/>
                    <Line X1="11" Y1="15" X2="15" Y2="15" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="GenericFileIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M4,2 C4,0.9 4.9,0 6,0 L14,0 L20,6 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 Z" Fill="{StaticResource GenericFileBrush}"/>
                    <Path Data="M14,0 L14,6 L20,6 Z" Fill="#30FFFFFF"/>
                    <Path Data="M8,10 H16 M8,13 H16 M8,16 H12" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.5"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="PinIconTemplate" TargetType="ContentControl">
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Data="M16,12 V4 H17 V2 H7 V4 H8 V12 L6,14 V16 H11 V22 H13 V16 H18 V14 Z" Fill="{StaticResource Blue600Brush}"/>
                </Canvas>
            </Viewbox>
        </ControlTemplate>

        <!-- Dynamic Icon Selector Style -->
        <Style x:Key="FileIconStyle" TargetType="ContentControl">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template" Value="{StaticResource GenericFileIconTemplate}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding FileCategory}" Value="Folder">
                    <Setter Property="Template" Value="{StaticResource FolderIconTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileCategory}" Value="Pdf">
                    <Setter Property="Template" Value="{StaticResource PdfIconTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileCategory}" Value="Image">
                    <Setter Property="Template" Value="{StaticResource ImageIconTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileCategory}" Value="Text">
                    <Setter Property="Template" Value="{StaticResource TextIconTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileCategory}" Value="Code">
                    <Setter Property="Template" Value="{StaticResource CodeIconTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileCategory}" Value="Archive">
                    <Setter Property="Template" Value="{StaticResource ArchiveIconTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileCategory}" Value="Audio">
                    <Setter Property="Template" Value="{StaticResource AudioIconTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileCategory}" Value="Video">
                    <Setter Property="Template" Value="{StaticResource VideoIconTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileCategory}" Value="Executable">
                    <Setter Property="Template" Value="{StaticResource ExecIconTemplate}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Static Folder Style for Sidebar/Tree -->
        <Style x:Key="SidebarFolderIconStyle" TargetType="ContentControl">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template" Value="{StaticResource FolderIconTemplate}"/>
        </Style>

        <!-- Static Pin Style for Sidebar Pinned Folders -->
        <Style x:Key="SidebarPinIconStyle" TargetType="ContentControl">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template" Value="{StaticResource PinIconTemplate}"/>
        </Style>

        <local:NullToVisibilityConverter x:Key="NullToVis"/>
        <local:NonNullToVisibilityConverter x:Key="NonNullToVis"/>

        <DataTemplate x:Key="FileThumbnailTemplate">
            <Border BorderBrush="{StaticResource Gray300Brush}" BorderThickness="1" CornerRadius="6" Background="White" Margin="6" Padding="6" Width="120" Height="140" ToolTip="{Binding Name}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="{StaticResource Gray050Brush}">
                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="2"
                               Visibility="{Binding Thumbnail, Converter={StaticResource NonNullToVis}}"/>
                        <ContentControl Style="{StaticResource FileIconStyle}" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding Thumbnail, Converter={StaticResource NullToVis}}"/>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="11" FontWeight="SemiBold" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" Foreground="{StaticResource Gray800Brush}"/>
                    <TextBlock Grid.Row="2" Text="{Binding Size}" FontSize="9" Foreground="{StaticResource Gray600Brush}" TextAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="FileThumbnailPanel">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

    </Window.Resources>



    <!-- ═══ Outer chrome ══════════════════════════════════════════════════ -->

    <Border x:Name="OuterBorder" Background="White" CornerRadius="10"

            BorderBrush="{StaticResource Gray300Brush}" BorderThickness="0.5">



        <Grid>

            <Grid.RowDefinitions>

                <RowDefinition Height="36"/>   <!-- title bar   -->

                <RowDefinition Height="Auto"/> <!-- ribbon tabs -->

                <RowDefinition Height="Auto"/> <!-- ribbon cmds -->

                <RowDefinition Height="Auto"/> <!-- address bar -->

                <RowDefinition Height="*"/>    <!-- body        -->

                <RowDefinition Height="26"/>   <!-- status bar  -->

            </Grid.RowDefinitions>



            <!-- ── Title Bar ──────────────────────────────────────── -->

            <Border x:Name="TitleBarBorder" Grid.Row="0"

                    Background="{StaticResource Blue800Brush}"

                    CornerRadius="10,10,0,0">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>



                    <!-- app name + path -->

                    <StackPanel Grid.Column="0" Orientation="Horizontal"

                                VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0">

                        <TextBlock Text="📁 " FontSize="13" Foreground="White" Opacity=".9"/>

                        <TextBlock Text="FileExplorer" FontSize="13" FontWeight="Medium"

                                   Foreground="White" Opacity=".9"/>

                        <TextBlock x:Name="TitlePathText" FontSize="11"

                                   Foreground="#88FFFFFF" Margin="10,0,0,0"

                                   VerticalAlignment="Center"/>

                    </StackPanel>



                    <!-- window controls -->

                    <StackPanel Grid.Column="1" Orientation="Horizontal"

                                VerticalAlignment="Stretch" HorizontalAlignment="Right">

                        <Button x:Name="MinimizeButton" WindowChrome.IsHitTestVisibleInChrome="True" Style="{StaticResource TitleBarButton}" Content="&#xE921;" ToolTip="Minimize" Click="MinimizeButton_Click" Tag="0"/>

                        <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButton}" Content="&#xE922;" ToolTip="Maximize" Click="MaximizeButton_Click" Tag="0"/>

                        <Button x:Name="CloseButton" WindowChrome.IsHitTestVisibleInChrome="True" Style="{StaticResource TitleBarCloseButton}" Content="&#xE8BB;" ToolTip="Close" Click="CloseButton_Click" Tag="0,10,0,0"/>

                    </StackPanel>

                </Grid>

            </Border>



            <!-- ── Ribbon Tab Row ─────────────────────────────────── -->

            <Border Grid.Row="1" Background="{StaticResource Blue900Brush}">

                <StackPanel Orientation="Horizontal" Margin="14,0,0,0">

                    <RadioButton x:Name="TabHome"    Content="Home"     GroupName="Ribbon"

                                 Style="{StaticResource RibbonTab}" IsChecked="True"

                                 Click="RibbonTab_Click"/>

                    <RadioButton x:Name="TabRename"  Content="Rename"   GroupName="Ribbon"

                                 Style="{StaticResource RibbonTab}" Click="RibbonTab_Click"/>

                    <RadioButton x:Name="TabOrganize" Content="Organize" GroupName="Ribbon"

                                 Style="{StaticResource RibbonTab}" Click="RibbonTab_Click"/>

                    <RadioButton x:Name="TabPdf"     Content="PDF Tools" GroupName="Ribbon"

                                 Style="{StaticResource RibbonTab}" Click="RibbonTab_Click"/>

                    <RadioButton x:Name="TabHelp"    Content="Help" GroupName="Ribbon"

                                 Style="{StaticResource RibbonTab}" Click="RibbonTab_Click"/>

                </StackPanel>

            </Border>



            <!-- ── Ribbon Command Row ─────────────────────────────── -->

            <Border Grid.Row="2" Background="{StaticResource Blue700Brush}"

                    Padding="14,6">
                <Grid>
                <!-- HOME -->
                <StackPanel x:Name="PanelHome" Orientation="Horizontal">
                    <Button Style="{StaticResource RibbonButton}"
                            Click="OpenFolderButton_OnClick" Margin="0,0,4,0">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="📂" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Open" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}"
                            Click="NewFolderButton_OnClick" Margin="0,0,4,0">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="📁" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="New folder" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>

                    <Button Style="{StaticResource RibbonButton}"
                            Click="RenameButton_OnClick" Margin="0,0,4,0">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="✏️" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Rename" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}"
                            Click="DeleteButton_OnClick" Margin="0,0,4,0">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="🗑️" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Delete" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>

                    <Button Style="{StaticResource RibbonButton}"
                            Click="SelectAllButton_OnClick" Margin="0,0,4,0">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="☑️" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Select all" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}"
                            Click="InvertSelectionButton_OnClick" Margin="0,0,4,0">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="🔄" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Invert" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}"
                            Click="RefreshButton_OnClick" Margin="0,0,4,0">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="🔃" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Refresh" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}"
                            Click="SearchButton_OnClick" Margin="0,0,4,0">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="🔍" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Search" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>

                    <Button x:Name="ListViewButton" Style="{StaticResource RibbonButton}"
                            Click="ListViewButton_OnClick" Margin="0,0,4,0" ToolTip="List View">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="☰" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="List view" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="GridViewButton" Style="{StaticResource RibbonButton}"
                            Click="GridViewButton_OnClick" ToolTip="Grid View">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="⊞" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Grid view" FontSize="10"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- RENAME -->
                <StackPanel x:Name="PanelRename" Orientation="Horizontal" Visibility="Collapsed">
                    <!-- GROUP 1: MODE SELECTOR -->
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,8,0">
                        <RadioButton x:Name="ModeBasicRadio" Content="Smart Mode" IsChecked="True" GroupName="RenameMode"
                                     Style="{StaticResource ModernRadio}" Foreground="White" Checked="RenameMode_Changed"/>
                        <RadioButton x:Name="ModeRegexRadio" Content="Regex Mode" GroupName="RenameMode"
                                     Style="{StaticResource ModernRadio}" Foreground="White" Checked="RenameMode_Changed"/>
                    </StackPanel>

                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>

                    <!-- GROUP 2: INPUTS (SMART VS REGEX) -->
                    <Grid VerticalAlignment="Center">
                        <!-- Smart Mode Inputs -->
                        <StackPanel x:Name="SmartModePanel" Orientation="Horizontal" Visibility="Visible">
                            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                                <TextBlock Text="Case Transform" FontSize="10" Foreground="#A0FFFFFF" Margin="0,0,0,2"/>
                                <ComboBox x:Name="SmartCaseTransformCombo" Width="110" Height="24"
                                          Style="{StaticResource ModernCombo}" FontSize="11" Padding="4,2"
                                          SelectedIndex="0" SelectionChanged="SmartPanel_OnAnyChange">
                                    <ComboBoxItem Content="No change" Tag="none"/>
                                    <ComboBoxItem Content="UPPERCASE" Tag="upper"/>
                                    <ComboBoxItem Content="lowercase" Tag="lower"/>
                                    <ComboBoxItem Content="Title Case" Tag="title"/>
                                    <ComboBoxItem Content="camelCase" Tag="camel"/>
                                    <ComboBoxItem Content="snake_case" Tag="snake"/>
                                </ComboBox>
                            </StackPanel>

                            <CheckBox x:Name="SmartStripDatesCheck" Content="Strip Dates" VerticalAlignment="Center"
                                      Style="{StaticResource ModernCheck}" Foreground="White" Margin="4,12,0,0"
                                      Checked="SmartPanel_OnAnyChange" Unchecked="SmartPanel_OnAnyChange"/>
                        </StackPanel>

                        <!-- Regex Mode Inputs -->
                        <StackPanel x:Name="RegexModePanel" Orientation="Horizontal" Visibility="Collapsed">
                            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                                <TextBlock Text="Find (Regex)" FontSize="10" Foreground="#A0FFFFFF" Margin="0,0,0,2"/>
                                <TextBox x:Name="RegexFindBox" Width="110" Height="24"
                                         Style="{StaticResource ModernTextBox}"
                                         TextChanged="SmartPanel_OnAnyChange"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                                <TextBlock Text="Replace" FontSize="10" Foreground="#A0FFFFFF" Margin="0,0,0,2"/>
                                <TextBox x:Name="RegexReplaceBox" Width="110" Height="24"
                                         Style="{StaticResource ModernTextBox}"
                                         TextChanged="SmartPanel_OnAnyChange"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="4,4,8,0">
                                <CheckBox x:Name="RegexIgnoreCaseCheck" Content="Ignore Case" IsChecked="True"
                                          Style="{StaticResource ModernCheck}" Foreground="White" FontSize="10" Height="14"
                                          Checked="SmartPanel_OnAnyChange" Unchecked="SmartPanel_OnAnyChange"/>
                                <CheckBox x:Name="RegexReplaceAllCheck" Content="Replace All" IsChecked="True"
                                          Style="{StaticResource ModernCheck}" Foreground="White" FontSize="10" Height="14"
                                          Checked="SmartPanel_OnAnyChange" Unchecked="SmartPanel_OnAnyChange"/>
                            </StackPanel>

                            <Border x:Name="RegexErrorBorder" Visibility="Collapsed" Background="#FFCCCC" BorderBrush="Red"
                                    BorderThickness="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" MaxWidth="150" Height="34">
                                <TextBlock x:Name="RegexErrorText" Foreground="Red" FontSize="9" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>

                    <!-- GROUP 3: NUMBERING -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Margin="0,0,6,0">
                            <CheckBox x:Name="SmartNumberingEnabledCheck" Content="Numbering"
                                      Style="{StaticResource ModernCheck}" Foreground="White" FontSize="11"
                                      Checked="SmartPanel_OnAnyChange" Unchecked="SmartPanel_OnAnyChange"/>
                            <ComboBox x:Name="SmartNumberingFormatCombo" Width="95" Height="24" Margin="0,2,0,0"
                                      Style="{StaticResource ModernCombo}" FontSize="11" Padding="4,2"
                                      SelectedIndex="0" SelectionChanged="SmartPanel_OnAnyChange">
                                <ComboBoxItem Tag="_001" Content="_001, _002..."/>
                                <ComboBoxItem Tag="_01"  Content="_01, _02..."/>
                                <ComboBoxItem Tag="_1"   Content="_1, _2..."/>
                                <ComboBoxItem Tag="-001" Content="-001, -002..."/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>

                    <!-- GROUP 4: DATE -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Margin="0,0,6,0">
                            <CheckBox x:Name="SmartDateEnabledCheck" Content="Add Date"
                                      Style="{StaticResource ModernCheck}" Foreground="White" FontSize="11"
                                      Checked="SmartPanel_OnAnyChange" Unchecked="SmartPanel_OnAnyChange"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <RadioButton x:Name="SmartDatePrefixRadio" Content="Pref" GroupName="DatePos" IsChecked="True"
                                             Style="{StaticResource ModernRadio}" Foreground="White" FontSize="10" Checked="SmartPanel_OnAnyChange"/>
                                <RadioButton x:Name="SmartDateSuffixRadio" Content="Suff" GroupName="DatePos"
                                             Style="{StaticResource ModernRadio}" Foreground="White" FontSize="10" Checked="SmartPanel_OnAnyChange" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,6,0">
                            <DatePicker x:Name="SmartDatePicker" Width="95" Height="24"
                                        Style="{StaticResource ModernDatePicker}" FontSize="11"
                                        SelectedDateChanged="SmartPanel_OnAnyChange"/>
                            <ComboBox x:Name="SmartDateFormatCombo" Width="105" Height="24" Margin="0,2,0,0"
                                      Style="{StaticResource ModernCombo}" FontSize="11" Padding="4,2"
                                      SelectedIndex="0" SelectionChanged="SmartPanel_OnAnyChange">
                                <ComboBoxItem Tag="yyyy-MM-dd" Content="yyyy-MM-dd"/>
                                <ComboBoxItem Tag="dd-MM-yyyy" Content="dd-MM-yyyy"/>
                                <ComboBoxItem Tag="yyyyMMdd"   Content="yyyyMMdd"/>
                                <ComboBoxItem Tag="MMM dd yyyy" Content="MMM dd yyyy"/>
                                <ComboBoxItem Tag="yyyy-MM"     Content="yyyy-mm"/>
                                <ComboBoxItem Tag="MMMM-yy"     Content="mmmm-yy"/>
                                <ComboBoxItem Tag="MMM-yy"      Content="mmm-yy"/>
                                <ComboBoxItem Tag="yyyy"        Content="yyyy"/>
                                <ComboBoxItem Tag="MM-yyyy"     Content="mm-yyyy"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>

                    <!-- GROUP 5: TAGS -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Margin="0,0,6,0">
                            <CheckBox x:Name="SmartTagEnabledCheck" Content="Add Tag"
                                      Style="{StaticResource ModernCheck}" Foreground="White" FontSize="11"
                                      Checked="SmartTagEnabledCheck_OnChange" Unchecked="SmartTagEnabledCheck_OnChange"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <RadioButton x:Name="SmartTagPrefixRadio" Content="Pref" GroupName="TagPos" IsChecked="True"
                                             Style="{StaticResource ModernRadio}" Foreground="White" FontSize="10" Checked="SmartPanel_OnAnyChange"/>
                                <RadioButton x:Name="SmartTagSuffixRadio" Content="Suff" GroupName="TagPos"
                                             Style="{StaticResource ModernRadio}" Foreground="White" FontSize="10" Checked="SmartPanel_OnAnyChange" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Orientation="Vertical" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="SmartTagComboBox" Width="90" Height="24" IsEditable="True"
                                          Style="{StaticResource ModernCombo}" FontSize="11" Padding="4,2"
                                          SelectionChanged="SmartTagComboBox_SelectionChanged"
                                          TextBoxBase.TextChanged="SmartTagComboBox_TextChanged"/>
                                <Button x:Name="SmartNewTagButton" Content="New" Width="30" Height="24" Margin="3,0,0,0"
                                        Style="{StaticResource RibbonButton}" Click="SmartNewTagButton_OnClick" ToolTip="Define new tag"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>

                    <!-- GROUP 6: PREVIEW & ACTIONS -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                        <Button x:Name="UndoButton" Style="{StaticResource RibbonButton}" Margin="0,0,4,0"
                                Click="UndoButton_OnClick" ToolTip="Undo the last action (Ctrl+Z)">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="↩️" FontSize="16" HorizontalAlignment="Center"/>
                                <TextBlock Text="Undo" FontSize="10"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="SmartApplyRenameButton" Style="{StaticResource RibbonButton}" Margin="0,0,4,0"
                                Click="SmartApplyRenameButton_OnClick" ToolTip="Apply the calculated rename to selected files">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="✏️" FontSize="16" HorizontalAlignment="Center"/>
                                <TextBlock Text="Apply rename" FontSize="10"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>





                <!-- ORGANIZE -->

                <StackPanel x:Name="PanelOrganize" Orientation="Horizontal" Visibility="Collapsed">

                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"

                            Click="SortButton_OnClick">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="🗂️" FontSize="16" HorizontalAlignment="Center"/>

                            <TextBlock Text="Sort files" FontSize="10"/>

                        </StackPanel>

                    </Button>

                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"

                            Click="BrowseArchive_Click">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="📦" FontSize="16" HorizontalAlignment="Center"/>

                            <TextBlock Text="Archive root" FontSize="10"/>

                        </StackPanel>

                    </Button>

                    <StackPanel Orientation="Vertical" Margin="4,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="Archive Root Path" FontSize="10" Foreground="#A0FFFFFF" Margin="0,0,0,2"/>
                        <TextBox x:Name="ArchivePathTextBox" Width="180" Height="24"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"

                            Click="MoveSelected_Click">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="➡️" FontSize="16" HorizontalAlignment="Center"/>

                            <TextBlock Text="Move to" FontSize="10"/>

                        </StackPanel>

                    </Button>

                </StackPanel>



                <!-- PDF -->

                <StackPanel x:Name="PanelPdf" Orientation="Horizontal" Visibility="Collapsed">

                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"

                            Click="MergePdfButton_OnClick">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="🔀" FontSize="16" HorizontalAlignment="Center"/>

                            <TextBlock Text="Merge" FontSize="10"/>

                        </StackPanel>

                    </Button>

                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"

                            Click="SplitPdfButton_OnClick">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="✂️" FontSize="16" HorizontalAlignment="Center"/>

                            <TextBlock Text="Split" FontSize="10"/>

                        </StackPanel>

                    </Button>

                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"

                            Click="CompressPdfButton_OnClick">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="🗜️" FontSize="16" HorizontalAlignment="Center"/>

                            <TextBlock Text="Compress" FontSize="10"/>

                        </StackPanel>

                    </Button>

                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"

                            Click="OcrPdfButton_OnClick">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="🔍" FontSize="16" HorizontalAlignment="Center"/>

                            <TextBlock Text="OCR" FontSize="10"/>

                        </StackPanel>

                    </Button>



                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>



                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"

                            Click="ConvertPdfButton_OnClick">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="📄" FontSize="16" HorizontalAlignment="Center"/>

                            <TextBlock Text="Convert→PDF" FontSize="10"/>

                        </StackPanel>

                    </Button>

                    <Button Style="{StaticResource RibbonButton}"

                            Click="ImagesToPdfButton_OnClick">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="🖼️" FontSize="16" HorizontalAlignment="Center"/>

                            <TextBlock Text="Images→PDF" FontSize="10"/>

                        </StackPanel>

                    </Button>

                </StackPanel>

                <!-- HELP -->
                <StackPanel x:Name="PanelHelp" Orientation="Horizontal" Visibility="Collapsed">
                    
                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"
                            Click="RegisterHelpButton_OnClick">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="🔑" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Activate Pro" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"
                            Click="BuyHelpButton_OnClick">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="💳" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Buy License" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    
                    <Separator Background="#33FFFFFF" Width="0.5" Margin="6,4"/>
                    
                    <Button Style="{StaticResource RibbonButton}" Margin="0,0,4,0"
                            Click="CheckUpdatesButton_OnClick">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="🔄" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Check Updates" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource RibbonButton}" IsEnabled="False">
                        <StackPanel Orientation="Vertical">
                            <TextBlock x:Name="HelpVersionIcon" Text="ℹ️" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="HelpVersionText" Text="v1.0.0 Trial" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    
                </StackPanel>

                            </Grid>

            </Border>



            <!-- ── Address Bar ───────────────────────────────────── -->

            <Border Grid.Row="3" Background="{StaticResource Blue600Brush}" Padding="12,6">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                        <Button x:Name="BackButton"    Style="{StaticResource NavButton}"
                                Content="‹" FontSize="16" Margin="0,0,4,0"
                                IsEnabled="False" Click="BackButton_OnClick"
                                ToolTip="Back"/>
                        <Button x:Name="ForwardButton" Style="{StaticResource NavButton}"
                                Content="›" FontSize="16" Margin="0,0,4,0"
                                IsEnabled="False" Click="ForwardButton_OnClick"
                                ToolTip="Forward"/>
                        <Button x:Name="UpButton"      Style="{StaticResource NavButton}"
                                Content="↑" FontSize="15" Margin="0,0,4,0"
                                IsEnabled="False" Click="UpButton_OnClick"
                                ToolTip="Up"/>
                    </StackPanel>

                    <TextBox x:Name="PathTextBox" Grid.Column="1"
                             Style="{StaticResource AddressTextBox}"
                             Height="28" VerticalContentAlignment="Center"
                             KeyDown="PathTextBox_OnKeyDown"
                             Margin="0,0,8,0"
                             Foreground="White"/>

                    <Grid Grid.Column="2" VerticalAlignment="Center">
                        <TextBox x:Name="SearchTextBox"
                                 Style="{StaticResource AddressTextBox}"
                                 Height="28" VerticalContentAlignment="Center"
                                 TextChanged="SearchTextBox_OnTextChanged"
                                 KeyDown="SearchTextBox_OnKeyDown"
                                 Foreground="White"/>
                        <TextBlock IsHitTestVisible="False"
                                   Text="🔍 Search current folder"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="8,0,0,0"
                                   Foreground="#A0FFFFFF"
                                   FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsFocused, ElementName=SearchTextBox}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                </Grid>

            </Border>



            <!-- ── Body ──────────────────────────────────────────── -->

            <Grid Grid.Row="4">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="150" MinWidth="100" MaxWidth="500"/>

                    <ColumnDefinition Width="3"/>

                    <ColumnDefinition Width="*" MinWidth="300"/>

                    <ColumnDefinition Width="3"/>

                    <ColumnDefinition Width="480" MinWidth="200" MaxWidth="800"/>

                </Grid.ColumnDefinitions>



                <!-- ── Left Panel ─────────────────────────────────── -->

                <Border Grid.Column="0" Background="{StaticResource Gray050Brush}"

                        BorderBrush="{StaticResource Gray300Brush}"

                        BorderThickness="0,0,0.5,0">

                    <Grid>

                        <ScrollViewer x:Name="FolderTreeScroll"

                                      Padding="6,6">

                            <Grid>

                                <StackPanel>

                                    <!-- Folders Section -->

                                    <Expander Header="PINNED FOLDERS" IsExpanded="True" BorderThickness="0" Margin="0,0,0,8" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}">

                                        <ListView x:Name="PinnedFoldersList"

                                                  BorderThickness="0"

                                                  Background="Transparent"

                                                  Padding="0"

                                                  SelectionMode="Single"

                                                  MouseDoubleClick="PinnedFoldersList_OnMouseDoubleClick">

                                            <ListView.ItemTemplate>

                                                <DataTemplate>

                                                    <StackPanel Orientation="Horizontal" Margin="4,2">

                                                        <ContentControl Style="{StaticResource SidebarPinIconStyle}" Margin="0,0,6,0" VerticalAlignment="Center"/>

                                                        <TextBlock Text="{Binding Name}" FontSize="11"

                                                                   Foreground="{StaticResource Gray700Brush}"

                                                                   VerticalAlignment="Center"

                                                                   TextTrimming="CharacterEllipsis"/>

                                                    </StackPanel>

                                                </DataTemplate>

                                            </ListView.ItemTemplate>

                                        </ListView>

                                    </Expander>



                                    <TextBlock Text="THIS PC" Style="{StaticResource SectionLabel}" Margin="4,4,0,4"/>

                                    <TreeView x:Name="FolderTree" Background="Transparent"

                                              BorderThickness="0"

                                              SelectedItemChanged="FolderTree_OnSelectedItemChanged"

                                              Margin="0,0,0,16">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="AllowDrop" Value="True"/>
                                                <EventSetter Event="DragOver" Handler="TreeViewItem_DragOver"/>
                                                <EventSetter Event="Drop" Handler="TreeViewItem_Drop"/>
                                            </Style>
                                        </TreeView.ItemContainerStyle>

                                        <TreeView.ItemTemplate>

                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">

                                                <StackPanel Orientation="Horizontal" Margin="0,1">

                                                    <ContentControl Style="{StaticResource SidebarFolderIconStyle}" Margin="0,0,6,0" VerticalAlignment="Center"/>

                                                    <TextBlock Text="{Binding Name}" FontSize="12"

                                                               Foreground="{StaticResource Gray700Brush}"/>

                                                </StackPanel>

                                            </HierarchicalDataTemplate>

                                        </TreeView.ItemTemplate>

                                    </TreeView>



                                    <Separator Style="{StaticResource Divider}" Margin="0,0,0,12"/>



                                    <!-- Favorites Section -->

                                    <TextBlock Text="BOOKMARKS" Style="{StaticResource SectionLabel}"/>

                                    <ListView x:Name="FavoritesList"

                                              BorderThickness="0"

                                              Background="Transparent"

                                              Padding="0"

                                              SelectionMode="Single"

                                              MouseDoubleClick="FavoritesList_OnMouseDoubleClick"

                                              Margin="0,0,0,8">

                                        <ListView.ItemTemplate>

                                            <DataTemplate>

                                                <StackPanel Orientation="Horizontal" Margin="4,2">

                                                    <ContentControl Style="{StaticResource SidebarFolderIconStyle}" Margin="0,0,6,0" VerticalAlignment="Center"/>

                                                    <TextBlock Text="{Binding Name}" FontSize="11"

                                                               Foreground="{StaticResource Gray700Brush}"

                                                               VerticalAlignment="Center"

                                                               TextTrimming="CharacterEllipsis"/>

                                                </StackPanel>

                                            </DataTemplate>

                                        </ListView.ItemTemplate>

                                    </ListView>



                                    <Separator Style="{StaticResource Divider}" Margin="0,10,0,6"/>



                                    <Button Content="Add current folder to favorites"

                                            Style="{StaticResource GhostButton}"

                                            HorizontalAlignment="Stretch"

                                            Padding="8,5"

                                            Click="AddFavoriteButton_Click"/>

                                    <Button Content="Remove selected"

                                            Style="{StaticResource GhostButton}"

                                            HorizontalAlignment="Stretch"

                                            Padding="8,5"

                                            Margin="0,4,0,0"

                                            Click="RemoveFavoriteButton_Click"/>

                                </StackPanel>

                            </Grid>

                        </ScrollViewer>

                    </Grid>

                </Border>



                <!-- Splitter 1 -->

                <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch"

                              Background="{StaticResource Gray200Brush}" Cursor="SizeWE"/>



                <!-- ── File List Area ──────────────────────────────── -->

                <Grid Grid.Column="2">

                    <Grid.RowDefinitions>

                        <RowDefinition Height="*"/>

                    </Grid.RowDefinitions>



                    <ListView x:Name="ItemsList"
                               SelectionMode="Extended"
                               AllowDrop="True"
                               DragOver="ItemsList_DragOver"
                               Drop="ItemsList_Drop"
                               SelectionChanged="ItemsList_OnSelectionChanged"
                               MouseDoubleClick="ItemsList_OnMouseDoubleClick"
                               PreviewMouseLeftButtonDown="ItemsList_PreviewMouseLeftButtonDown"
                               PreviewMouseLeftButtonUp="ItemsList_PreviewMouseLeftButtonUp"
                               MouseMove="ItemsList_MouseMove"
                               Padding="4,4"
                               ItemContainerStyle="{StaticResource FileListItemStyle}">

                        <ListView.View>

                            <GridView>

                                <GridViewColumn Header="Name" Width="200">

                                    <GridViewColumn.CellTemplate>

                                        <DataTemplate>

                                            <StackPanel Orientation="Horizontal" Margin="6,0">

                                                <ContentControl Style="{StaticResource FileIconStyle}" Margin="0,0,7,0" VerticalAlignment="Center"/>

                                                <TextBlock Text="{Binding Name}"

                                                           FontSize="12" FontWeight="Medium"

                                                           Foreground="{StaticResource Gray800Brush}"

                                                           VerticalAlignment="Center"

                                                           TextTrimming="CharacterEllipsis"/>

                                                <Border Style="{StaticResource TagPill}"

                                                        Margin="6,0,0,0"

                                                        Visibility="{Binding Tag, Converter={StaticResource StringToVis}}">

                                                    <TextBlock Text="{Binding Tag}"

                                                               FontSize="10"

                                                               Foreground="{StaticResource Blue800Brush}"

                                                               FontWeight="Medium"/>

                                                </Border>

                                            </StackPanel>

                                        </DataTemplate>

                                    </GridViewColumn.CellTemplate>

                                </GridViewColumn>

                                <GridViewColumn x:Name="ColChangeBaseName" Width="190">
                                    <GridViewColumn.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox x:Name="HeaderMarkAllCheck" VerticalAlignment="Center" Margin="0,0,6,0"
                                                      Checked="HeaderMarkAllCheck_Checked" Unchecked="HeaderMarkAllCheck_Unchecked"
                                                      Style="{StaticResource ModernCheck}"/>
                                            <TextBlock Text="Change Base Name" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Width="175">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsMarkedForRename, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center" Margin="2,0,6,0" Grid.Column="0"
                                                          Style="{StaticResource ModernCheck}"/>
                                                <TextBox Text="{Binding BaseName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Padding="4,2" Height="24"
                                                         VerticalContentAlignment="Center"
                                                         BorderBrush="{StaticResource Gray300Brush}"
                                                         BorderThickness="1" Background="White"
                                                         PreviewKeyDown="BaseNameTextBox_PreviewKeyDown" Grid.Column="1"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn x:Name="ColNewName" Header="New Name" Width="160">

                                    <GridViewColumn.CellTemplate>

                                        <DataTemplate>

                                            <TextBlock Text="{Binding NewName}"

                                                       FontSize="11" VerticalAlignment="Center"

                                                       Foreground="{StaticResource GreenAccentBrush}"

                                                       FontFamily="Consolas"

                                                       TextTrimming="CharacterEllipsis"/>

                                        </DataTemplate>

                                    </GridViewColumn.CellTemplate>

                                </GridViewColumn>

                                <GridViewColumn Header="Type"     DisplayMemberBinding="{Binding Type}"     Width="100"/>

                                <GridViewColumn Header="Size"     DisplayMemberBinding="{Binding Size}"     Width="80"/>

                                <GridViewColumn Header="Modified" DisplayMemberBinding="{Binding Modified}" Width="140"/>

                            </GridView>

                        </ListView.View>

                    </ListView>

                </Grid>



                <!-- Splitter 2 -->

                <GridSplitter Grid.Column="3" Width="3" HorizontalAlignment="Stretch"

                              Background="{StaticResource Gray200Brush}" Cursor="SizeWE"/>



                <!-- ── Right Inspector Panel ──────────────────────── -->

                <Border Grid.Column="4" Background="{StaticResource Gray050Brush}"

                        BorderBrush="{StaticResource Gray300Brush}"

                        BorderThickness="0.5,0,0,0">

                    <Grid>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="*"/>

                        </Grid.RowDefinitions>



                        <!-- Inspector header + tabs -->

                        <Border Grid.Row="0" Background="White"

                                BorderBrush="{StaticResource Gray200Brush}"

                                BorderThickness="0,0,0,0.5">

                            <StackPanel>

                                <TextBlock Text="INSPECTOR" FontSize="10" FontWeight="Medium"

                                           Foreground="{StaticResource Gray500Brush}"

                                           Margin="14,10,14,4"/>

                                <Grid>

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="*"/>

                                        <ColumnDefinition Width="*"/>

                                    </Grid.ColumnDefinitions>

                                    <RadioButton Grid.Column="0" x:Name="InspectorPreviewTab"

                                                 Content="Preview" GroupName="Inspector"

                                                 IsChecked="True"

                                                 Style="{StaticResource InspectorTab}"

                                                 Click="InspectorTab_Click"/>

                                    <RadioButton Grid.Column="1" x:Name="InspectorDetailsTab"

                                                 Content="Details" GroupName="Inspector"

                                                 Style="{StaticResource InspectorTab}"

                                                 Click="InspectorTab_Click"/>

                                </Grid>

                            </StackPanel>

                        </Border>



                        <!-- Inspector body scroll -->
                        <ScrollViewer Grid.Row="1" Padding="14,12,14,4">
                            <StackPanel>

                                <!-- Preview pane -->
                                <StackPanel x:Name="PreviewPane">
                                    <!-- Thumbnail / image container -->
                                    <Border x:Name="PreviewThumbContainer"
                                            Background="{StaticResource Gray100Brush}"
                                            BorderBrush="{StaticResource Gray300Brush}"
                                            BorderThickness="0.5" CornerRadius="8"
                                            MinHeight="260" Margin="0,0,0,6"
                                            Focusable="True" FocusVisualStyle="{x:Null}"
                                            PreviewMouseWheel="PreviewThumbContainer_PreviewMouseWheel"
                                            MouseLeftButtonDown="PreviewThumbContainer_MouseLeftButtonDown">
                                        <Grid>
                                            <!-- Hint text (no selection) -->
                                            <TextBlock x:Name="PreviewHintText"
                                                       Text="Select a file to preview"
                                                       FontSize="12"
                                                       Foreground="{StaticResource Gray500Brush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"/>

                                            <!-- Image preview -->
                                            <ScrollViewer x:Name="PreviewScrollHost"
                                                          Visibility="Collapsed"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto">
                                                <Image x:Name="PreviewImage"
                                                       Stretch="Uniform" MaxHeight="500"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Top"/>
                                            </ScrollViewer>

                                            <!-- PDF WebView2 -->
                                            <wv2:WebView2 x:Name="PreviewPdfView"
                                                          Visibility="Collapsed"
                                                          MinHeight="400"/>

                                            <!-- Text preview -->
                                            <TextBox x:Name="PreviewTextBox"
                                                     Visibility="Collapsed"
                                                     IsReadOnly="True"
                                                     TextWrapping="Wrap"
                                                     FontFamily="Consolas"
                                                     FontSize="11"
                                                     Foreground="{StaticResource Gray700Brush}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="10"
                                                     MaxHeight="450"
                                                     VerticalScrollBarVisibility="Auto"/>

                                            <!-- Message / fallback -->
                                            <TextBlock x:Name="PreviewMessageText"
                                                       Visibility="Collapsed"
                                                       TextWrapping="Wrap"
                                                       FontSize="11"
                                                       Foreground="{StaticResource Gray600Brush}"
                                                       Background="{StaticResource Gray100Brush}"
                                                       Padding="10" TextAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- File name + type -->
                                    <TextBlock x:Name="PreviewHeaderText"
                                               Text="Preview"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource Gray800Brush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,2"/>

                                    <!-- Zoom row (images only) -->
                                    <Grid x:Name="ZoomRow" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Zoom"
                                                   Style="{StaticResource LabelText}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Slider Grid.Column="1" x:Name="ZoomSlider"
                                                Style="{StaticResource ZoomSlider}"
                                                VerticalAlignment="Center"
                                                ValueChanged="ZoomSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ZoomValueText"
                                                   Text="100%" FontSize="11"
                                                   Foreground="{StaticResource Gray600Brush}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" MinWidth="36"/>
                                    </Grid>

                                </StackPanel>



                                <!-- Details pane -->

                                <StackPanel x:Name="DetailsPane" Visibility="Collapsed">



                                    <!-- Detail rows -->

                                    <TextBlock Text="ORIGINAL NAME" Style="{StaticResource SectionLabel}"/>

                                    <TextBlock x:Name="DetailsOriginalName" Text="—"

                                               Style="{StaticResource BaseText}" FontSize="12"

                                               Margin="0,0,0,10"/>



                                    <Separator Style="{StaticResource Divider}"/>



                                    <Grid Margin="0,6,0,6">

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="*"/>

                                            <ColumnDefinition Width="*"/>

                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">

                                            <TextBlock Text="TYPE" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"/>

                                            <TextBlock x:Name="DetailsType" Text="—" FontSize="12"

                                                       Foreground="{StaticResource Gray700Brush}"/>

                                        </StackPanel>

                                        <StackPanel Grid.Column="1">

                                            <TextBlock Text="SIZE" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"/>

                                            <TextBlock x:Name="DetailsSize" Text="—" FontSize="12"

                                                       Foreground="{StaticResource Gray700Brush}"/>

                                        </StackPanel>

                                    </Grid>



                                    <Separator Style="{StaticResource Divider}"/>



                                    <TextBlock Text="MODIFIED" Style="{StaticResource SectionLabel}"/>

                                    <TextBlock x:Name="DetailsDate" Text="—" FontSize="12"

                                               Foreground="{StaticResource Gray700Brush}"

                                               Margin="0,0,0,10"/>



                                    <Separator Style="{StaticResource Divider}"/>



                                    <TextBlock Text="FOLDER" Style="{StaticResource SectionLabel}"/>

                                    <TextBlock x:Name="DetailsFolder" Text="—" FontSize="11"

                                               Foreground="{StaticResource Gray600Brush}"

                                               TextWrapping="Wrap"

                                               Margin="0,0,0,10"/>



                                    <Separator Style="{StaticResource Divider}"/>



                                    <TextBlock Text="NEW NAME" Style="{StaticResource SectionLabel}"/>

                                    <TextBox x:Name="DetailsNewName"

                                             Style="{StaticResource ModernTextBox}"

                                             Height="28" VerticalContentAlignment="Center"

                                             IsEnabled="False"

                                             TextChanged="DetailsNewName_TextChanged"/>

                                </StackPanel>



                            </StackPanel>

                        </ScrollViewer>

                    </Grid>

                </Border>

            </Grid>



            <!-- ── Status Bar ─────────────────────────────────────── -->

            <Border Grid.Row="5"
                    Background="{StaticResource Gray050Brush}"
                    BorderBrush="{StaticResource Gray200Brush}"
                    BorderThickness="0,0.5,0,0"
                    CornerRadius="0,0,10,10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ProgressBar x:Name="StatusProgressBar" Grid.Row="0"
                                 Height="3" BorderThickness="0" Background="Transparent"
                                 Foreground="#1976D2" IsIndeterminate="True"
                                 Visibility="Collapsed"/>

                    <Grid Grid.Row="1" Margin="14,0">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="*"/>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="Auto"/>

                        </Grid.ColumnDefinitions>

                        <Ellipse x:Name="StatusDot" Grid.Column="0" Width="6" Height="6"

                                 Fill="#28C840" Margin="0,0,8,0"

                                 VerticalAlignment="Center"/>

                        <TextBlock x:Name="StatusText" Grid.Column="1"

                                   Text="Ready" FontSize="11"

                                   Foreground="{StaticResource Gray600Brush}"

                                   VerticalAlignment="Center"/>

                        <TextBlock x:Name="FileCountText" Grid.Column="2"

                                   Text="" FontSize="11"

                                   Foreground="{StaticResource Gray500Brush}"

                                   VerticalAlignment="Center"

                                   Margin="16,0,0,0"/>

                        <TextBlock x:Name="SelectionCountText" Grid.Column="3"

                                   Text="" FontSize="11"

                                   Foreground="{StaticResource Gray500Brush}"

                                   VerticalAlignment="Center"

                                   Margin="16,0,0,0"/>

                        <TextBlock x:Name="FreeSpaceText" Grid.Column="4"

                                   Text="" FontSize="11"

                                   Foreground="{StaticResource Gray500Brush}"

                                   VerticalAlignment="Center"

                                   Margin="16,0,0,0"/>

                        <StackPanel x:Name="TrialStatusContainer" Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="TrialStatusText" Text="Trial Mode: 14 days remaining" FontSize="11" Foreground="{DynamicResource AmberAccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button x:Name="UnlockProButton" Content="Unlock Pro" Margin="8,0,0,0" Padding="8,2" FontSize="10" Style="{StaticResource ActionButton}" Height="20" Click="UnlockProButton_Click"/>
                        </StackPanel>

                    </Grid>
                </Grid>

            </Border>



        </Grid>

    </Border>

</Window>

