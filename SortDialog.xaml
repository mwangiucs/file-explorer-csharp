<Window x:Class="FileExplorerCS.SortDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sort Files"
        Width="640" Height="580"
        MinWidth="520" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ThemeLight.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Section label -->
            <Style x:Key="SLabel" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize"   Value="10"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="{DynamicResource Gray500Brush}"/>
                <Setter Property="Margin"     Value="0,10,0,5"/>
            </Style>

            <!-- ModernRadio -->
            <Style x:Key="MRadio" TargetType="RadioButton">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource Gray700Brush}"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="Margin"     Value="0,2"/>
            </Style>

            <!-- ModernCheck -->
            <Style x:Key="MCheck" TargetType="CheckBox">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource Gray700Brush}"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="Margin"     Value="0,2"/>
            </Style>

            <!-- TextBox -->
            <Style x:Key="MBox" TargetType="TextBox">
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Background"      Value="{DynamicResource WhiteBrush}"/>
                <Setter Property="Foreground"      Value="{DynamicResource Gray800Brush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource Gray300Brush}"/>
                <Setter Property="BorderThickness" Value="0.5"/>
                <Setter Property="Padding"         Value="7,4"/>
                <Setter Property="Height"          Value="32"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource Blue600Brush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Ghost button -->
            <Style x:Key="GBtn" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource Gray300Brush}"/>
                <Setter Property="BorderThickness" Value="0.5"/>
                <Setter Property="Foreground"      Value="{DynamicResource Gray700Brush}"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Padding"         Value="12,6"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background"  Value="{DynamicResource Blue050Brush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource Blue200Brush}"/>
                                    <Setter Property="Foreground"  Value="{DynamicResource Blue600Brush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary (blue) button -->
            <Style x:Key="PBtn" TargetType="Button">
                <Setter Property="Background"      Value="{DynamicResource Blue600Brush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="FontWeight"      Value="Medium"/>
                <Setter Property="Padding"         Value="20,8"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Blue700Brush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Blue800Brush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Option card (radio-button-styled border) -->
            <Style x:Key="OptionCard" TargetType="Border">
                <Setter Property="Background"      Value="{DynamicResource WhiteBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource Gray300Brush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="7"/>
                <Setter Property="Padding"         Value="12,10"/>
                <Setter Property="Margin"          Value="0,0,6,0"/>
                <Setter Property="Cursor"          Value="Hand"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- ── Outer chrome ────────────────────────────────────────────────── -->
    <Border Background="{DynamicResource WhiteBrush}" CornerRadius="10"
            BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="0.5">
        <Border.Effect>
            <DropShadowEffect Color="#20000000" BlurRadius="18" ShadowDepth="3" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>  <!-- title bar  -->
                <RowDefinition Height="*"/>   <!-- body        -->
                <RowDefinition Height="Auto"/><!-- footer       -->
            </Grid.RowDefinitions>

            <!-- ── Title bar ─────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Blue800Brush}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <TextBlock Text="🗂️  Sort Files"
                               FontFamily="Segoe UI" FontSize="14" FontWeight="Medium"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Content="✕" Foreground="White" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4" Padding="6,2">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Body (two-column: options | preview) ──────────────── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: Options ───────────────────────────────────── -->
                <ScrollViewer Grid.Column="0"
                              Background="{DynamicResource Gray050Brush}"
                              Padding="16,12"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- DATE FOLDER ─────────────────────────────────── -->
                        <TextBlock Text="DATE FOLDER" Style="{StaticResource SLabel}" Margin="0,0,0,6"/>

                        <!-- Date option cards -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- No date -->
                            <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource OptionCard}"
                                    Margin="0,0,4,4" MouseLeftButtonDown="DateNoneCard_Click"
                                    x:Name="DateNoneCard">
                                <StackPanel>
                                    <RadioButton x:Name="DateNoneRadio" Content="" GroupName="DateMode"
                                                 Style="{StaticResource MRadio}"
                                                 Checked="AnyOption_Changed"/>
                                    <TextBlock Text="No date" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource Gray800Brush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="Flat, no date subfolder"
                                               FontSize="10" Foreground="{DynamicResource Gray500Brush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- By year -->
                            <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource OptionCard}"
                                    Margin="0,0,0,4" MouseLeftButtonDown="DateYearCard_Click"
                                    x:Name="DateYearCard">
                                <StackPanel>
                                    <RadioButton x:Name="DateYearRadio" Content="" GroupName="DateMode"
                                                 Style="{StaticResource MRadio}"
                                                 Checked="AnyOption_Changed"/>
                                    <TextBlock Text="By year" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource Gray800Brush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="2024 /"
                                               FontSize="10" Foreground="{DynamicResource Gray500Brush}"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                            </Border>

                            <!-- By month (default) -->
                            <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource OptionCard}"
                                    Margin="0,0,4,0" MouseLeftButtonDown="DateMonthCard_Click"
                                    x:Name="DateMonthCard"
                                    BorderBrush="{DynamicResource Blue600Brush}">
                                <StackPanel>
                                    <RadioButton x:Name="DateMonthRadio" Content="" GroupName="DateMode"
                                                 IsChecked="True"
                                                 Style="{StaticResource MRadio}"
                                                 Checked="AnyOption_Changed"/>
                                    <TextBlock Text="By month" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource Blue600Brush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="2024-06 /"
                                               FontSize="10" Foreground="{DynamicResource Blue200Brush}"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                            </Border>

                            <!-- By day -->
                            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource OptionCard}"
                                    MouseLeftButtonDown="DateDayCard_Click"
                                    x:Name="DateDayCard">
                                <StackPanel>
                                    <RadioButton x:Name="DateDayRadio" Content="" GroupName="DateMode"
                                                 Style="{StaticResource MRadio}"
                                                 Checked="AnyOption_Changed"/>
                                    <TextBlock Text="By day" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource Gray800Brush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="2024-06-15 /"
                                               FontSize="10" Foreground="{DynamicResource Gray500Brush}"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SUBFOLDERS ──────────────────────────────────── -->
                        <TextBlock Text="SUBFOLDERS" Style="{StaticResource SLabel}"/>

                        <Border Background="{DynamicResource WhiteBrush}" BorderBrush="{DynamicResource Gray200Brush}"
                                BorderThickness="0.5" CornerRadius="7" Padding="12,10">
                            <StackPanel>
                                <CheckBox x:Name="TagFolderCheck"
                                          Style="{StaticResource MCheck}"
                                          Checked="AnyOption_Changed"
                                          Unchecked="AnyOption_Changed">
                                    <StackPanel>
                                        <TextBlock Text="Group by tag" FontSize="12"
                                                   Foreground="{DynamicResource Gray800Brush}"/>
                                        <TextBlock Text="Uses _#tag embedded in filename"
                                                   FontSize="10" Foreground="{DynamicResource Gray500Brush}"/>
                                    </StackPanel>
                                </CheckBox>
                                <Separator Background="{DynamicResource Gray200Brush}" Height="0.5" Margin="0,8"/>
                                <CheckBox x:Name="ExtFolderCheck"
                                          Style="{StaticResource MCheck}"
                                          Checked="AnyOption_Changed"
                                          Unchecked="AnyOption_Changed">
                                    <StackPanel>
                                        <TextBlock Text="Group by extension" FontSize="12"
                                                   Foreground="{DynamicResource Gray800Brush}"/>
                                        <TextBlock Text="e.g. PDF / DOCX / JPG"
                                                   FontSize="10" Foreground="{DynamicResource Gray500Brush}"/>
                                    </StackPanel>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <!-- ARCHIVE ROOT ─────────────────────────────────── -->
                        <TextBlock Text="DESTINATION" Style="{StaticResource SLabel}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ArchivePathBox" Grid.Column="0"
                                     Style="{StaticResource MBox}"
                                     Margin="0,0,4,0"
                                     TextChanged="AnyOption_Changed"/>
                            <Button Grid.Column="1" Content="…"
                                    Style="{StaticResource GBtn}"
                                    Width="34" Padding="0"
                                    Click="BrowseArchive_Click"/>
                        </Grid>

                        <TextBlock Text="Leave as current folder to sort in place."
                                   FontSize="10" Foreground="{DynamicResource Gray500Brush}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>

                        <!-- DUPLICATES ──────────────────────────────────── -->
                        <TextBlock Text="IF FILE ALREADY EXISTS" Style="{StaticResource SLabel}"/>

                        <Border Background="{DynamicResource WhiteBrush}" BorderBrush="{DynamicResource Gray200Brush}"
                                BorderThickness="0.5" CornerRadius="7" Padding="12,10">
                            <StackPanel>
                                <RadioButton x:Name="DupeRenameRadio"
                                             Content="Auto-rename  (Report (1).pdf)"
                                             GroupName="DupeMode" IsChecked="True"
                                             Style="{StaticResource MRadio}"
                                             Checked="AnyOption_Changed"/>
                                <RadioButton x:Name="DupeSkipRadio"
                                             Content="Skip  (leave in place)"
                                             GroupName="DupeMode"
                                             Style="{StaticResource MRadio}"
                                             Checked="AnyOption_Changed"/>
                                <RadioButton x:Name="DupeOverwriteRadio"
                                             Content="Overwrite"
                                             GroupName="DupeMode"
                                             Style="{StaticResource MRadio}"
                                             Checked="AnyOption_Changed"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── Right: Live preview ─────────────────────────────── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource WhiteBrush}"
                            BorderBrush="{DynamicResource Gray200Brush}"
                            BorderThickness="0.5,0,0,0.5"
                            Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LIVE PREVIEW" FontFamily="Segoe UI" FontSize="10"
                                       FontWeight="Medium" Foreground="{DynamicResource Gray500Brush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="PreviewCountText"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="{DynamicResource Gray500Brush}"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Preview list -->
                    <ListView x:Name="PreviewList" Grid.Row="1"
                              Background="{DynamicResource WhiteBrush}"
                              BorderThickness="0.5,0,0,0"
                              BorderBrush="{DynamicResource Gray200Brush}"
                              FontFamily="Segoe UI" FontSize="12"
                              IsHitTestVisible="False">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="File" Width="180">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="FILE" FontSize="10" FontWeight="Medium"
                                                       Foreground="{DynamicResource Gray500Brush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FileName}"
                                                       FontSize="11" FontFamily="Consolas"
                                                       Foreground="{DynamicResource Gray700Brush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Destination folder" Width="240">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="DESTINATION FOLDER" FontSize="10"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource Gray500Brush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DestFolder}"
                                                       FontSize="11" FontFamily="Consolas"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource GreenAccentBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource RedAccentBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding"     Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    Padding="0,1">
                                                <GridViewRowPresenter Columns="{TemplateBinding GridView.ColumnCollection}"
                                                                      Content="{TemplateBinding Content}"
                                                                      VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#F1F3F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <!-- Date-detection info strip -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource Blue050Brush}"
                            BorderBrush="{DynamicResource Blue100Brush}"
                            BorderThickness="0.5,0.5,0,0"
                            Padding="14,8">
                        <TextBlock Text="📅  Dates are detected from filenames automatically (ISO, compact, month-name). Falls back to file modified date."
                                   FontSize="10" Foreground="{DynamicResource Blue600Brush}"
                                   TextWrapping="Wrap" FontFamily="Segoe UI"/>
                    </Border>
                </Grid>
            </Grid>

            <!-- ── Footer ─────────────────────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Gray050Brush}"
                    BorderBrush="{DynamicResource Gray200Brush}"
                    BorderThickness="0,0.5,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- File count summary -->
                    <TextBlock x:Name="FooterSummary" Grid.Column="0"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{DynamicResource Gray600Brush}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="Cancel"
                            Style="{StaticResource GBtn}"
                            Margin="0,0,8,0"
                            Click="Cancel_Click"/>

                    <Button Grid.Column="2" Content="Sort files  →"
                            Style="{StaticResource PBtn}"
                            Click="Sort_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
