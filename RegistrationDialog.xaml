<Window x:Class="FileExplorerCS.RegistrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Activation" Height="360" Width="440" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="{DynamicResource Gray100Brush}"/>
            <Setter Property="Foreground" Value="{DynamicResource Gray800Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Gray300Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Blue500Brush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                                <Setter Property="Background" Value="{DynamicResource WhiteBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="{DynamicResource WhiteBrush}" 
            BorderBrush="{DynamicResource Gray200Brush}" 
            BorderThickness="1" 
            CornerRadius="10">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> <!-- Custom Title Bar -->
                <RowDefinition Height="*"/>  <!-- Main Content -->
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource Gray050Brush}" CornerRadius="9,9,0,0" MouseDown="TitleBar_MouseDown">
                <Grid Margin="12,0">
                    <TextBlock Text="Product Activation" 
                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" 
                               Foreground="{DynamicResource Gray800Brush}" 
                               VerticalAlignment="Center"/>
                    <Button x:Name="CloseButton" Content="&#xE8BB;" 
                            FontFamily="Segoe MDL2 Assets" FontSize="10" 
                            Foreground="{DynamicResource Gray600Brush}" 
                            Background="Transparent" BorderThickness="0" 
                            HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Width="28" Height="28" Click="CloseButton_Click"/>
                </Grid>
            </Border>
            
            <!-- Main Content Area -->
            <Grid Grid.Row="1" Margin="24,16,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title / Status -->
                    <RowDefinition Height="Auto"/> <!-- Info text -->
                    <RowDefinition Height="Auto"/> <!-- Fields -->
                    <RowDefinition Height="*"/>    <!-- Buttons -->
                </Grid.RowDefinitions>
                
                <!-- Title / Status Icon & Text -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock x:Name="TrialIcon" Text="&#xE99A;" 
                               FontFamily="Segoe MDL2 Assets" FontSize="24" 
                               Foreground="{DynamicResource AmberAccentBrush}" 
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock x:Name="StatusTitleText" Text="Trial Mode Active" 
                                   FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" 
                                   Foreground="{DynamicResource Gray800Brush}"/>
                        <TextBlock x:Name="StatusDetailText" Text="14 days remaining on your trial." 
                                   FontFamily="Segoe UI" FontSize="11" 
                                   Foreground="{DynamicResource Gray500Brush}"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Info text -->
                <TextBlock Grid.Row="1" Text="Please enter your license details to activate the premium version of FileExplorerCS." 
                           TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12" 
                           Foreground="{DynamicResource Gray600Brush}" Margin="0,0,0,16"/>
                
                <!-- Input Fields -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <!-- License Email -->
                    <TextBlock Text="License Email" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" 
                               Foreground="{DynamicResource Gray700Brush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="EmailTextBox" />
                    
                    <!-- License Key -->
                    <TextBlock Text="License Key" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" 
                               Foreground="{DynamicResource Gray700Brush}" Margin="0,12,0,6"/>
                    <TextBox x:Name="KeyTextBox" />
                    
                    <!-- Feedback Message -->
                    <TextBlock x:Name="ErrorMessageText" Text="" FontFamily="Segoe UI" FontSize="11" FontWeight="Medium" 
                               Foreground="{DynamicResource RedAccentBrush}" Margin="0,8,0,0" Visibility="Collapsed"/>
                </StackPanel>
                
                <!-- Action Buttons -->
                <Grid Grid.Row="3" VerticalAlignment="Bottom">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Test Key & Checkout buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="HelperButton" Content="Generate Test Key" 
                                Height="32" Padding="0,0" Background="Transparent" 
                                Foreground="{DynamicResource Blue500Brush}" BorderThickness="0" 
                                FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                Click="HelperButton_Click"/>
                        
                        <TextBlock Text="|" Foreground="{DynamicResource Gray300Brush}" Margin="8,0" VerticalAlignment="Center" FontSize="11"/>
                        
                        <Button x:Name="BuyButton" Content="Buy License ($19)" 
                                Height="32" Padding="0,0" Background="Transparent" 
                                Foreground="{DynamicResource GreenAccentBrush}" BorderThickness="0" 
                                FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Cursor="Hand"
                                Click="BuyButton_Click"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="CancelButton" Style="{StaticResource DialogButton}" Content="Exit Application" 
                                Width="110" Height="32" Margin="0,0,8,0"
                                Background="Transparent" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" 
                                Foreground="{DynamicResource Gray700Brush}" Click="CancelButton_Click"/>
                        
                        <Button x:Name="RegisterButton" Style="{StaticResource DialogButton}" Content="Activate" 
                                Width="90" Height="32" IsDefault="True"
                                Background="{DynamicResource Blue600Brush}" BorderThickness="0" 
                                Foreground="White" Click="RegisterButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
