<Window x:Class="FileExplorerCS.PdfMetadataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit PDF Metadata"
        Height="340"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F8FF">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="14" Foreground="#1976D2" FontWeight="SemiBold" Text="Edit PDF Metadata Fields" />

        <Border Grid.Row="2" BorderBrush="#90CAF9" BorderThickness="1" CornerRadius="8" Background="White" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#374151" Text="Title:" />
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TitleTextBox" Height="28" VerticalContentAlignment="Center" BorderBrush="#CED4DA" BorderThickness="1" Padding="6,0" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#374151" Text="Author:" />
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="AuthorTextBox" Height="28" VerticalContentAlignment="Center" BorderBrush="#CED4DA" BorderThickness="1" Padding="6,0" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#374151" Text="Subject:" />
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="SubjectTextBox" Height="28" VerticalContentAlignment="Center" BorderBrush="#CED4DA" BorderThickness="1" Padding="6,0" />

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Top" Margin="0,4,0,0" FontSize="12" Foreground="#374151" Text="Keywords:" />
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="KeywordsTextBox" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderBrush="#CED4DA" BorderThickness="1" Padding="6,4" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Width="80" Height="34" Margin="0,0,10,0" Click="CancelButton_OnClick"
                    Background="#E3F2FD" BorderBrush="#90CAF9" Foreground="#1976D2" FontSize="12" FontWeight="Medium" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                             BorderBrush="{TemplateBinding BorderBrush}" 
                                             BorderThickness="1" 
                                             CornerRadius="5"
                                             Padding="10,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>Cancel
            </Button>
            <Button x:Name="SaveButton" Width="80" Height="34" Click="SaveButton_OnClick"
                    Background="#1976D2" BorderBrush="#1565C0" Foreground="White" FontSize="12" FontWeight="Medium" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                             BorderBrush="{TemplateBinding BorderBrush}" 
                                             BorderThickness="1" 
                                             CornerRadius="5"
                                             Padding="10,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>Save
            </Button>
        </StackPanel>
    </Grid>
</Window>
