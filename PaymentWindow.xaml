<Window x:Class="FileExplorerCS.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Secure Checkout" Height="500" Width="680" 
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab RadioButton Style -->
        <Style x:Key="PaymentTabStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="PaymentTabs"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="tabBorder" Background="Transparent" 
                                BorderBrush="Transparent" BorderThickness="0,0,0,2.5" 
                                Padding="12,8" Cursor="Hand" Margin="0,0,16,0">
                            <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="{DynamicResource Blue500Brush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Blue500Brush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Gray500Brush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="{DynamicResource Gray050Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="{DynamicResource Gray100Brush}"/>
            <Setter Property="Foreground" Value="{DynamicResource Gray800Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Gray300Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Blue500Brush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                                <Setter Property="Background" Value="{DynamicResource WhiteBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="{DynamicResource WhiteBrush}" 
            BorderBrush="{DynamicResource Gray200Brush}" 
            BorderThickness="1" 
            CornerRadius="10">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> <!-- Custom Title Bar -->
                <RowDefinition Height="*"/>  <!-- Main Content -->
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource Gray050Brush}" CornerRadius="9,9,0,0" MouseDown="TitleBar_MouseDown">
                <Grid Margin="12,0">
                    <TextBlock Text="Complete Checkout" 
                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" 
                               Foreground="{DynamicResource Gray800Brush}" 
                               VerticalAlignment="Center"/>
                    <Button x:Name="CloseButton" Content="&#xE8BB;" 
                            FontFamily="Segoe MDL2 Assets" FontSize="10" 
                            Foreground="{DynamicResource Gray600Brush}" 
                            Background="Transparent" BorderThickness="0" 
                            HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Width="28" Height="28" Click="CloseButton_Click"/>
                </Grid>
            </Border>
            
            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>    <!-- Left Column: Payment Form -->
                    <ColumnDefinition Width="250"/>  <!-- Right Column: Order Summary -->
                </Grid.ColumnDefinitions>

                <!-- Left Column Content: Payment Form Grid -->
                <Grid Grid.Column="0" Margin="24,16,24,20" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Tabs -->
                        <RowDefinition Height="*"/>    <!-- Method Content -->
                        <RowDefinition Height="Auto"/> <!-- Error Message -->
                        <RowDefinition Height="Auto"/> <!-- Bottom Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Method Select Tabs -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton x:Name="CardTabButton" Style="{StaticResource PaymentTabStyle}" Content="Credit / Debit Card" IsChecked="True" Checked="PaymentTab_Checked"/>
                        <RadioButton x:Name="MpesaTabButton" Style="{StaticResource PaymentTabStyle}" Content="M-Pesa (Mobile Money)" Checked="PaymentTab_Checked"/>
                    </StackPanel>

                    <!-- Method Fields Content -->
                    <Grid Grid.Row="1">
                        <!-- Card Payment Panel -->
                        <StackPanel x:Name="CardPanel" Visibility="Visible">
                            <!-- Card Intro Panel -->
                            <StackPanel x:Name="CardIntroPanel" Visibility="Visible">
                                <Border Background="{DynamicResource Gray050Brush}" BorderBrush="{DynamicResource Gray200Brush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="💳" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Hosted Card Checkout" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Gray800Brush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Payments are processed securely via Lemon Squeezy, our global Merchant of Record. Your card details are never transmitted to or stored by this application." 
                                                   TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11.5" Foreground="{DynamicResource Gray600Brush}" LineHeight="16" Margin="0,0,0,8"/>
                                        <TextBlock Text="Supported payment options include Visa, Mastercard, American Express, Discover, and localized options based on your region." 
                                                   TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray500Brush}" LineHeight="15"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Click 'Pay $19.00' below to open the checkout page in your default web browser." TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Blue600Brush}"/>
                            </StackPanel>

                            <!-- Card Awaiting Panel (shown after browser launch) -->
                            <StackPanel x:Name="CardAwaitingPanel" Visibility="Collapsed">
                                <Border Background="{DynamicResource Gray050Brush}" BorderBrush="{DynamicResource Gray200Brush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Center">
                                            <TextBlock Text="🌐" FontSize="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Checkout Session Started" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Gray800Brush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="We have opened a secure checkout page in your default web browser. Please complete the purchase there." 
                                                   TextWrapping="Wrap" TextAlignment="Center" FontFamily="Segoe UI" FontSize="11.5" Foreground="{DynamicResource Gray600Brush}" LineHeight="16" Margin="0,0,0,12"/>
                                        
                                        <Border BorderBrush="{DynamicResource Gray200Brush}" BorderThickness="1" CornerRadius="6" Padding="12,8" Background="{DynamicResource WhiteBrush}">
                                            <StackPanel>
                                                <TextBlock Text="What to do next:" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Gray700Brush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="1. Complete the payment in your web browser." FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}"/>
                                                <TextBlock Text="2. Check your email for your unique license key." FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}"/>
                                                <TextBlock Text="3. Paste the key in the Registration window to activate." FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="You can close this checkout window. The Registration dialog remains open." TextWrapping="Wrap" TextAlignment="Center" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray500Brush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- M-Pesa Payment Panel -->
                        <StackPanel x:Name="MpesaPanel" Visibility="Collapsed">
                            <TextBlock Text="M-Pesa Registered Phone Number" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Gray700Brush}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Country prefix label -->
                                <Border Background="{DynamicResource Gray200Brush}" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1,1,0,1" CornerRadius="6,0,0,6" Height="32" Padding="8,0" VerticalAlignment="Center">
                                    <TextBlock Text="+254" VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="12" Foreground="{DynamicResource Gray600Brush}"/>
                                </Border>

                                <TextBox x:Name="MpesaPhoneBox" Grid.Column="1" Height="32" MaxLength="10" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="0,1,1,1"
                                                    CornerRadius="0,6,6,0"
                                                    SnapsToDevicePixels="True">
                                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" 
                                                              HorizontalScrollBarVisibility="Hidden" 
                                                              VerticalScrollBarVisibility="Hidden"
                                                              Margin="{TemplateBinding Padding}"
                                                              VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Blue500Brush}"/>
                                                    <Setter TargetName="border" Property="BorderThickness" Value="0,1.5,1.5,1.5"/>
                                                    <Setter Property="Background" Value="{DynamicResource WhiteBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                            </Grid>

                            <TextBlock Text="Enter number in format 07XXXXXXXX or 7XXXXXXXX" FontFamily="Segoe UI" FontSize="10" Foreground="{DynamicResource Gray500Brush}" Margin="0,4,0,12"/>

                            <Border BorderBrush="{DynamicResource Gray200Brush}" BorderThickness="1" CornerRadius="6" Padding="12" Background="{DynamicResource Gray050Brush}">
                                <StackPanel>
                                    <TextBlock Text="How it works:" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Gray700Brush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="1. Click the Pay button below." TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}"/>
                                    <TextBlock Text="2. Safaricom will send an STK Push PIN prompt directly to your phone." TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}"/>
                                    <TextBlock Text="3. Enter your M-Pesa PIN on your phone to complete the transaction." TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}"/>
                                    <TextBlock Text="4. The application will auto-activate immediately after PIN entry." TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Error Message Display -->
                    <TextBlock x:Name="ErrorMessageText" Grid.Row="2" Text="" FontFamily="Segoe UI" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource RedAccentBrush}" Margin="0,8,0,8" Visibility="Collapsed"/>

                    <!-- Bottom Action Buttons -->
                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="CancelButton" Style="{StaticResource DialogButton}" Grid.Column="0" Content="Cancel" Width="90" Height="34" HorizontalAlignment="Left" Background="Transparent" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" Foreground="{DynamicResource Gray700Brush}" Click="CancelButton_Click"/>

                        <Button x:Name="PayButton" Style="{StaticResource DialogButton}" Grid.Column="1" Content="Pay $19.00" Width="140" Height="34" Background="{DynamicResource Blue600Brush}" BorderThickness="0" Foreground="White" Click="PayButton_Click" IsDefault="True"/>
                    </Grid>
                </Grid>

                <!-- Right Column Content: Order Summary Panel -->
                <Border Grid.Column="1" Background="{DynamicResource Gray050Brush}" BorderBrush="{DynamicResource Gray200Brush}" BorderThickness="1,0,0,0" CornerRadius="0,0,9,0" Padding="20,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Title -->
                            <RowDefinition Height="Auto"/> <!-- Item list -->
                            <RowDefinition Height="*"/>    <!-- Spacer -->
                            <RowDefinition Height="Auto"/> <!-- Breakdown -->
                            <RowDefinition Height="Auto"/> <!-- SSL Badge -->
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <TextBlock Grid.Row="0" Text="Order Summary" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Gray800Brush}" Margin="0,0,0,16"/>

                        <!-- Item list -->
                        <StackPanel Grid.Row="1">
                            <Grid Margin="0,0,0,12">
                                <StackPanel Width="150" HorizontalAlignment="Left">
                                    <TextBlock Text="FileExplorerCS Pro" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Gray800Brush}"/>
                                    <TextBlock Text="Lifetime License" FontFamily="Segoe UI" FontSize="10" Foreground="{DynamicResource Gray500Brush}"/>
                                </StackPanel>
                                <TextBlock Text="$19.00" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource Gray800Brush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- Breakdown -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,16">
                            <Separator Background="{DynamicResource Gray200Brush}" Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Subtotal" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}"/>
                                <TextBlock Text="$19.00" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="VAT / Tax (0%)" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}"/>
                                <TextBlock Text="$0.00" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Separator Background="{DynamicResource Gray200Brush}" Margin="0,8,0,8"/>

                            <Grid>
                                <TextBlock Text="Total due" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource Gray800Brush}"/>
                                <TextBlock Text="$19.00" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Blue600Brush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- SSL & Guarantee Badges -->
                        <StackPanel Grid.Row="4" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="🔒" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Secure 256-bit SSL checkout" FontFamily="Segoe UI" FontSize="10" Foreground="{DynamicResource Gray500Brush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="30-Day Money Back Guarantee" FontFamily="Segoe UI" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource Gray400Brush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Loading / Processing Overlay (hidden by default) -->
                <Grid x:Name="ProcessingOverlay" Background="#E6FFFFFF" Visibility="Collapsed" Grid.ColumnSpan="2">
                    <!-- Dynamic theme fallback for dark mode -->
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                    <Setter Property="Background" Value="#E61E1E1E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                        <TextBlock x:Name="OverlayIcon" Text="&#xEA3A;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="{DynamicResource Blue500Brush}" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0" CenterX="18" CenterY="18"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <TextBlock x:Name="OverlayStatusText" Text="Processing transaction..." FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Gray800Brush}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="OverlaySubText" Text="Please do not close the window." FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray500Brush}" HorizontalAlignment="Center"/>

                        <ProgressBar x:Name="OverlayProgress" Height="4" Width="200" BorderThickness="0" Background="{DynamicResource Gray200Brush}" Foreground="{DynamicResource Blue500Brush}" IsIndeterminate="True" Margin="0,16,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Payment Success Panel (hidden by default) -->
                <Grid x:Name="SuccessPanel" Visibility="Collapsed" Grid.ColumnSpan="2" Background="{DynamicResource WhiteBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <TextBlock Text="&#xE930;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{DynamicResource GreenAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Payment Successful!" FontFamily="Segoe UI" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Gray800Brush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Thank you for activating FileExplorerCS Pro!" FontFamily="Segoe UI" FontSize="12" Foreground="{DynamicResource Gray600Brush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                        <Border BorderBrush="{DynamicResource Gray200Brush}" BorderThickness="1" CornerRadius="8" Padding="16,12" Background="{DynamicResource Gray050Brush}" Width="360" Margin="0,0,0,32">
                            <StackPanel>
                                <TextBlock Text="YOUR LICENSE KEY" FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Gray500Brush}" Margin="0,0,0,4"/>
                                <Grid>
                                    <TextBlock x:Name="SuccessEmailText" Text="test@example.com" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource Gray600Brush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SuccessKeyText" Text="XXXXX-XXXXX-XXXXX-XXXXX" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource Blue600Brush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Button x:Name="StartButton" Style="{StaticResource DialogButton}" Content="Activate &amp; Get Started" Width="180" Height="36" Background="{DynamicResource Blue600Brush}" BorderThickness="0" Foreground="White" Click="StartButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
